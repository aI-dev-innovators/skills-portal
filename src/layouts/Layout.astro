---
import '../styles/global.css';

const { title = 'Skills Portal', description = 'Portal interno de skills' } = Astro.props;
const session = Astro.locals.session;
const user = Astro.locals.user;
const displayName = user?.name || user?.email || 'Usuario';
const avatar = user?.image || null;
const currentPath = Astro.url.pathname.replace(/\/+$/, '') || '/';

const navItems = [
  { href: '/', label: 'Inicio' },
  { href: '/skills', label: 'Skills' },
  { href: '/rankings', label: 'Rankings' },
  { href: '/repos', label: 'Repos' }
];

function isActivePath(href: string): boolean {
  const normalizedHref = href.replace(/\/+$/, '') || '/';
  if (normalizedHref === '/') return currentPath === '/';
  return currentPath === normalizedHref || currentPath.startsWith(`${normalizedHref}/`);
}
---

<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <script is:inline>
      (() => {
        try {
          const savedTheme = localStorage.getItem('skills-portal-theme');
          const theme = savedTheme === 'dark' ? 'dark' : 'light';
          document.documentElement.dataset.theme = theme;
          document.documentElement.style.colorScheme = theme;
        } catch {
          document.documentElement.dataset.theme = 'light';
          document.documentElement.style.colorScheme = 'light';
        }
      })();
    </script>
  </head>
  <body>
    <a class="skip-link" href="#main-content">Saltar al contenido</a>
    <header class="site-header">
      <div class="shell shell--header">
        <a class="brand" href="/" aria-label="Ir al inicio de Skills Portal">Skills Portal</a>
        <nav class="main-nav" aria-label="Navegacion principal">
          {navItems.map((item) => (
            <a
              href={item.href}
              class:list={{ 'is-active': isActivePath(item.href) }}
              aria-current={isActivePath(item.href) ? 'page' : undefined}
            >
              {item.label}
            </a>
          ))}
        </nav>
        <div class="header-tools">
          <button
            id="theme-toggle"
            class="theme-toggle"
            type="button"
            role="switch"
            aria-label="Cambiar tema"
            aria-checked="false"
          >
            <span class="theme-toggle__track" aria-hidden="true">
              <span class="theme-toggle__thumb"></span>
            </span>
            <span id="theme-toggle-label" class="theme-toggle__label">Claro</span>
          </button>
          {session && user ? (
            <div class="auth-user" aria-label="Sesion activa">
              {avatar ? <img src={avatar} alt="Avatar" class="auth-avatar" /> : <span class="auth-avatar auth-avatar-fallback">{displayName.slice(0, 1).toUpperCase()}</span>}
              <span class="auth-name">{displayName}</span>
              <button id="logout-button" class="auth-action" type="button">Salir</button>
            </div>
          ) : (
            <a class="auth-action" href="/login/">Ingresar</a>
          )}
        </div>
      </div>
    </header>
    <main id="main-content" class="shell">
      <slot />
    </main>
    <footer class="site-footer">
      <div class="shell">Portal interno — estático y seguro.</div>
    </footer>

    <div id="page-loader" aria-hidden="true">
      <div class="spinner" aria-label="Cargando"></div>
      <p>Cargando...</p>
    </div>

    <script>
      import { trackLinkClick } from '../lib/client-telemetry';
      const { signOut } = await import('../lib/auth-client');
      const themeStorageKey = 'skills-portal-theme';

      // Preloader para transiciones de página y clics en navegación.
      const loader = document.getElementById('page-loader');
      const showLoader = () => loader?.classList.add('visible');
      const hideLoader = () => loader?.classList.remove('visible');

      window.addEventListener('pageshow', hideLoader);
      window.addEventListener('load', hideLoader);
      window.addEventListener('beforeunload', showLoader);

      const root = document.documentElement;
      const themeToggle = document.getElementById('theme-toggle');
      const themeToggleLabel = document.getElementById('theme-toggle-label');

      const updateThemeUi = (theme: string) => {
        const isDark = theme === 'dark';
        if (themeToggle) {
          themeToggle.setAttribute('aria-checked', String(isDark));
          themeToggle.setAttribute('aria-label', isDark ? 'Activar tema claro' : 'Activar tema oscuro');
          themeToggle.classList.toggle('is-dark', isDark);
        }
        if (themeToggleLabel) themeToggleLabel.textContent = isDark ? 'Oscuro' : 'Claro';
      };

      const applyTheme = (theme: string) => {
        const safeTheme = theme === 'dark' ? 'dark' : 'light';
        root.dataset.theme = safeTheme;
        root.style.colorScheme = safeTheme;
        updateThemeUi(safeTheme);
      };

      const getInitialTheme = () => {
        try {
          const savedTheme = localStorage.getItem(themeStorageKey);
          return savedTheme === 'dark' ? 'dark' : 'light';
        } catch {
          return 'light';
        }
      };

      applyTheme(getInitialTheme());

      themeToggle?.addEventListener('click', () => {
        const nextTheme = root.dataset.theme === 'dark' ? 'light' : 'dark';
        applyTheme(nextTheme);
        try {
          localStorage.setItem(themeStorageKey, nextTheme);
        } catch {
          // Ignora storage bloqueado; mantiene preferencia en runtime.
        }
      });

      document.addEventListener('click', (event) => {
        const target = event.target as HTMLElement | null;
        const anchor = target?.closest?.('a');
        if (!anchor) return;

        const href = anchor.getAttribute('href') || '';
        const newTab = anchor.getAttribute('target') === '_blank';
        const isDownload = anchor.hasAttribute('download');
        const isAnchor = href.startsWith('#');
        const isMail = href.startsWith('mailto:');
        const isTel = href.startsWith('tel:');

        if (newTab || isDownload || isAnchor || isMail || isTel) return;
        trackLinkClick(href);
        showLoader();
      });

      const logoutButton = document.getElementById('logout-button');
      logoutButton?.addEventListener('click', async () => {
        showLoader();
        await signOut({
          fetchOptions: {
            onSuccess: () => {
              window.location.href = '/login/';
            }
          }
        });
      });
    </script>
  </body>
</html>
