---
import { readReposConfig } from '../lib/config';

export async function getStaticPaths() {
  const repos = readReposConfig();
  return repos.map((repo) => ({ params: { slug: repo.id } }));
}

const { slug } = Astro.params;
const base = Astro.site?.pathname || '';

// Rutas conocidas que ya tienen página propia; se dejan tal cual.
const reserved = new Set(['', 'skills', 'repos', 'search']);

if (!slug || reserved.has(slug)) {
  return Astro.redirect(`${base}/`);
}

// Redirige slugs huérfanos a la página de repos correspondiente.
return Astro.redirect(`${base}/repos/${slug}`);
---
