---
import Layout from '../../layouts/Layout.astro';
import { readReposConfig } from '../../lib/config';
import { requireToken } from '../../lib/github.service';
import { collectAllSkills } from '../../lib/skill.service';
import { getBadgeDefinition } from '../../lib/badge.service';

requireToken();
const repos = await readReposConfig();
const skills = (await collectAllSkills(repos)).sort((a, b) => a.title.localeCompare(b.title));

const repoOptions = Array.from(new Set(skills.map((s) => s.repoName || s.repoId))).sort();
const frameworkOptions = Array.from(new Set(skills.flatMap((s) => s.frameworks || []))).sort();
const levelOptions = Array.from(new Set(skills.map((s) => s.level))).sort();
const testTypeOptions = Array.from(new Set(skills.flatMap((s) => s.testTypes || []))).sort();
const statusOptions = Array.from(new Set(skills.map((s) => s.status))).sort();

const totalSkills = skills.length;
const skillsWithExamples = skills.filter((skill) => skill.hasExamples).length;
const skillsRecommended = skills.filter((skill) => skill.status === 'recommended').length;
const avgEstimatedTime =
  skills.reduce((acc, skill) => acc + (typeof skill.estimatedTime === 'number' ? skill.estimatedTime : 0), 0) /
  Math.max(skills.filter((skill) => typeof skill.estimatedTime === 'number').length, 1);
const recommendedRatio = totalSkills > 0 ? Math.round((skillsRecommended / totalSkills) * 100) : 0;
const examplesRatio = totalSkills > 0 ? Math.round((skillsWithExamples / totalSkills) * 100) : 0;
const frameworkDistribution = frameworkOptions
  .map((framework) => ({
    framework,
    count: skills.filter((skill) => (skill.frameworks || []).includes(framework)).length
  }))
  .sort((a, b) => b.count - a.count)
  .slice(0, 4);

const CARD_FRAMEWORK_LIMIT = 2;
const CARD_TEST_TYPE_LIMIT = 2;
const CARD_BADGE_LIMIT = 2;
const CARD_ASSET_LIMIT = 3;
---
<Layout title="Skills" description="Catálogo de skills con metadata enriquecida">
  <section class="hero">
    <div class="hero-copy">
      <p class="eyebrow">Skills Catalog</p>
      <h1>Explora skills por framework, nivel y tipo de prueba</h1>
      <p class="lede">
        Descubre skills listas para ejecutar con filtros facetados, badges de activos disponibles y señales editoriales de madurez.
      </p>
      <div class="kpi-strip">
        <article class="kpi-card">
          <span>Total skills</span>
          <strong>{totalSkills}</strong>
        </article>
        <article class="kpi-card">
          <span>Con ejemplos</span>
          <strong>{skillsWithExamples}</strong>
        </article>
        <article class="kpi-card">
          <span>Recommended</span>
          <strong>{skillsRecommended}</strong>
        </article>
        <article class="kpi-card">
          <span>Tiempo promedio</span>
          <strong>{Math.round(avgEstimatedTime || 0)} min</strong>
        </article>
      </div>

      <div class="hero-addon" aria-label="Resumen adicional del catálogo">
        <article class="insight-card">
          <p class="insight-title">Radar del catálogo</p>
          <div class="insight-list">
            <p><span>Cobertura recommended</span><strong>{recommendedRatio}%</strong></p>
            <p><span>Con ejemplos disponibles</span><strong>{examplesRatio}%</strong></p>
            <p><span>Tiempo estimado acumulado</span><strong>{Math.round((avgEstimatedTime || 0) * totalSkills)} min</strong></p>
          </div>
        </article>

        <article class="insight-card">
          <p class="insight-title">Frameworks con más skills</p>
          <div class="framework-stack">
            {frameworkDistribution.length === 0 ? (
              <p class="hint">Sin datos de frameworks por ahora.</p>
            ) : (
              frameworkDistribution.map((item) => (
                <div class="framework-row">
                  <span>{item.framework}</span>
                  <strong>{item.count}</strong>
                </div>
              ))
            )}
          </div>
          <div class="hero-links">
            <a href="/rankings">Ver rankings</a>
            <a href="/repos">Explorar repos</a>
          </div>
        </article>
      </div>
    </div>

    <aside class="facet-panel" aria-label="Filtros de skills">
      <p class="panel-title">Filtrar skills</p>
      <div class="facet-fields">
        <label class="field field-full">
          Buscar
          <input id="skill-search" type="search" placeholder="Ej. angular, jest, coverage" oninput="filterSkills()" />
        </label>
        <label class="field">
          Repositorio
          <select id="skill-repo" onchange="filterSkills()">
            <option value="">Todos</option>
            {repoOptions.map((repo) => (
              <option value={repo.toLowerCase()}>{repo}</option>
            ))}
          </select>
        </label>
        <label class="field">
          Framework
          <select id="skill-framework" onchange="filterSkills()">
            <option value="">Todos</option>
            {frameworkOptions.map((framework) => (
              <option value={framework}>{framework}</option>
            ))}
          </select>
        </label>
        <label class="field">
          Nivel
          <select id="skill-level" onchange="filterSkills()">
            <option value="">Todos</option>
            {levelOptions.map((level) => (
              <option value={level}>{level}</option>
            ))}
          </select>
        </label>
        <label class="field">
          Tipo de test
          <select id="skill-test-type" onchange="filterSkills()">
            <option value="">Todos</option>
            {testTypeOptions.map((testType) => (
              <option value={testType}>{testType}</option>
            ))}
          </select>
        </label>
        <label class="field field-full">
          Estado
          <select id="skill-status" onchange="filterSkills()">
            <option value="">Todos</option>
            {statusOptions.map((status) => (
              <option value={status}>{status}</option>
            ))}
          </select>
        </label>
      </div>
      <div class="toggle-row">
        <label class="inline-check">
          <input id="skill-examples-only" type="checkbox" onchange="filterSkills()" />
          Solo con examples
        </label>
        <label class="inline-check">
          <input id="skill-recommended-only" type="checkbox" onchange="filterSkills()" />
          Solo recommended
        </label>
      </div>
      <button class="facet-reset" type="button" onclick="resetSkillFilters()">Limpiar filtros</button>
      <p class="hint">El filtrado se ejecuta en cliente para respuesta inmediata.</p>
    </aside>
  </section>

  <section class="results-head">
    <h2>Resultados</h2>
    <div class="results-actions">
      <p id="results-count" aria-live="polite">{totalSkills} skills visibles</p>
      <a class="excel-export" href="/api/skills-export/" download>Descargar Excel consolidado</a>
    </div>
  </section>

  <section>
    {skills.length === 0 ? (
      <p class="hint">No hay skills registradas.</p>
    ) : (
      <>
        <div class="skills-grid" id="skills-grid">
          {skills.map((skill) => {
            const frameworks = skill.frameworks || [];
            const testTypes = skill.testTypes || [];
            const badges = skill.badges || [];
            const assets = [
              skill.hasExamples ? 'Examples' : null,
              skill.hasTemplates ? 'Templates' : null,
              skill.hasEvals ? 'Evals' : null,
              skill.hasScripts ? 'Scripts' : null,
              skill.status === 'recommended' ? 'Recommended' : null
            ].filter((asset): asset is string => Boolean(asset));

            const visibleFrameworks = frameworks.slice(0, CARD_FRAMEWORK_LIMIT);
            const visibleTestTypes = testTypes.slice(0, CARD_TEST_TYPE_LIMIT);
            const visibleBadges = badges.slice(0, CARD_BADGE_LIMIT);
            const visibleAssets = assets.slice(0, CARD_ASSET_LIMIT);

            const hiddenFrameworks = Math.max(frameworks.length - visibleFrameworks.length, 0);
            const hiddenTestTypes = Math.max(testTypes.length - visibleTestTypes.length, 0);
            const hiddenBadges = Math.max(badges.length - visibleBadges.length, 0);
            const hiddenAssets = Math.max(assets.length - visibleAssets.length, 0);

            return (
              <article
                class="skill-card"
                data-title={skill.title.toLowerCase()}
                data-desc={skill.description.toLowerCase()}
                data-tags={(skill.tags || []).join(' ').toLowerCase()}
                data-frameworks={frameworks.join(' ').toLowerCase()}
                data-level={(skill.level || '').toLowerCase()}
                data-test-types={testTypes.join(' ').toLowerCase()}
                data-status={(skill.status || '').toLowerCase()}
                data-repo={(skill.repoName || skill.repoId || '').toLowerCase()}
                data-has-examples={skill.hasExamples ? 'true' : 'false'}
              >
                <header>
                  <p class="repo">{skill.repoName || skill.repoId}</p>
                  <h3><a href={`/skills/${skill.id}/`}>{skill.title}</a></h3>
                  <p class="desc">{skill.description}</p>
                </header>

                <div class="meta-row">
                  <span class="meta-chip">{skill.level}</span>
                  <span class="meta-chip">{skill.status}</span>
                  {typeof skill.estimatedTime === 'number' && <span class="meta-chip">{skill.estimatedTime} min</span>}
                  <span class="meta-chip">v{skill.version}</span>
                </div>

                <div class="taxonomy-row">
                  {visibleFrameworks.map((framework) => (
                    <span class="tag framework">{framework}</span>
                  ))}
                  {hiddenFrameworks > 0 && <span class="tag tag--overflow">+{hiddenFrameworks}</span>}

                  {visibleTestTypes.map((testType) => (
                    <span class="tag type">{testType}</span>
                  ))}
                  {hiddenTestTypes > 0 && <span class="tag tag--overflow">+{hiddenTestTypes}</span>}
                </div>

                <div class="badge-row">
                  {visibleBadges.map((badgeType) => {
                    const badgeDef = getBadgeDefinition(badgeType);
                    const colorMap = {
                      'green': '#10b981',
                      'blue': '#3b82f6',
                      'purple': '#a855f7',
                      'amber': '#f59e0b',
                      'pink': '#ec4899'
                    };
                    const badgeColor = colorMap[badgeDef.color as keyof typeof colorMap];
                    return (
                      <span
                        class="auto-badge"
                        title={badgeDef.tooltip}
                        style={`background: ${badgeColor}20; border-color: ${badgeColor}50; color: ${badgeColor}`}
                      >
                        {badgeDef.icon} {badgeDef.label}
                      </span>
                    );
                  })}
                  {hiddenBadges > 0 && <span class="auto-badge auto-badge--overflow">+{hiddenBadges}</span>}
                </div>

                <div class="asset-row">
                  {visibleAssets.map((asset) => (
                    <span class={`badge${asset === 'Recommended' ? ' featured' : ''}`}>{asset}</span>
                  ))}
                  {hiddenAssets > 0 && <span class="badge badge--overflow">+{hiddenAssets}</span>}
                </div>
              </article>
            );
          })}
        </div>
        <p id="skills-empty-state" class="empty-results" hidden>
          No hay skills que coincidan con los filtros actuales.
        </p>

        <nav class="pagination" id="skills-pagination" aria-label="Paginacion del listado de skills">
          <button type="button" id="pagination-prev" onclick="goToPreviousPage()">Anterior</button>
          <p id="pagination-status">Pagina 1 de 1</p>
          <button type="button" id="pagination-next" onclick="goToNextPage()">Siguiente</button>
        </nav>
      </>
    )}
  </section>

  <style>
    .hero {
      display: grid;
      grid-template-columns: 1.85fr minmax(280px, 340px);
      gap: 1.5rem;
      align-items: start;
      padding: 2rem;
      border: 1px solid var(--border);
      border-radius: 18px;
      background:
        radial-gradient(circle at 20% 20%, rgba(61, 217, 196, 0.18), transparent 35%),
        radial-gradient(circle at 80% 0%, rgba(255, 180, 84, 0.14), transparent 32%),
        var(--panel);
      box-shadow: var(--shadow-soft);
    }

    .eyebrow {
      text-transform: uppercase;
      letter-spacing: 0.12em;
      font-size: 0.8rem;
      color: var(--login-eyebrow);
      margin: 0 0 0.4rem;
    }

    h1 {
      margin: 0;
      font-size: clamp(1.8rem, 3vw, 2.4rem);
      letter-spacing: -0.02em;
    }

    .lede {
      color: var(--muted);
      margin: 0.6rem 0 1.2rem;
      max-width: 720px;
      line-height: 1.5;
    }

    .kpi-strip {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
      gap: 1rem;
    }

    .hero-addon {
      margin-top: 1rem;
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 0.85rem;
    }

    .insight-card {
      border: 1px solid var(--border);
      background: color-mix(in srgb, var(--panel-elevated) 74%, transparent);
      border-radius: 12px;
      padding: 0.75rem 0.85rem;
      display: grid;
      gap: 0.55rem;
    }

    .insight-title {
      margin: 0;
      font-size: 0.8rem;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: var(--login-eyebrow);
      font-weight: 700;
    }

    .insight-list {
      display: grid;
      gap: 0.4rem;
    }

    .insight-list p {
      margin: 0;
      padding: 0.44rem 0.55rem;
      border-radius: 8px;
      background: color-mix(in srgb, var(--panel-elevated) 82%, transparent);
      border: 1px solid var(--border);
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 0.5rem;
      font-size: 0.85rem;
      color: var(--muted);
    }

    .insight-list strong {
      color: var(--text);
      font-size: 0.9rem;
    }

    .framework-stack {
      display: grid;
      gap: 0.36rem;
    }

    .framework-row {
      padding: 0.44rem 0.55rem;
      border-radius: 8px;
      background: color-mix(in srgb, var(--panel-elevated) 82%, transparent);
      border: 1px solid var(--border);
      display: flex;
      justify-content: space-between;
      align-items: center;
      font-size: 0.85rem;
      color: var(--muted);
    }

    .framework-row strong {
      color: var(--text);
      min-width: 26px;
      text-align: right;
    }

    .hero-links {
      display: flex;
      gap: 0.5rem;
      flex-wrap: wrap;
    }

    .hero-links a {
      border: 1px solid var(--border-strong);
      background: var(--action-bg);
      color: var(--action-text);
      text-decoration: none;
      border-radius: 8px;
      padding: 0.35rem 0.6rem;
      font-size: 0.78rem;
      font-weight: 700;
    }

    .hero-links a:hover {
      background: var(--action-bg-hover);
      color: var(--nav-active-text);
    }

    .kpi-card {
      background: color-mix(in srgb, var(--panel-elevated) 78%, transparent);
      border: 1px solid var(--border);
      border-radius: 12px;
      padding: 0.9rem 1rem;
      display: grid;
      gap: 0.2rem;
    }

    .kpi-card span {
      color: var(--muted);
      font-size: 0.9rem;
      text-transform: uppercase;
      letter-spacing: 0.06em;
    }

    .kpi-card strong {
      font-weight: 700;
      font-size: 1.2rem;
    }

    .facet-panel {
      background: color-mix(in srgb, var(--panel-elevated) 80%, transparent);
      border: 1px solid var(--border);
      border-radius: 14px;
      padding: 0.95rem;
      backdrop-filter: blur(6px);
      align-self: start;
      justify-self: end;
      display: grid;
      gap: 0.7rem;
      width: min(100%, 318px);
      position: relative;
      overflow: hidden;
    }

    .facet-panel::before {
      content: "";
      position: absolute;
      inset: 0 0 auto 0;
      height: 2px;
      background: linear-gradient(90deg, rgba(56, 189, 248, 0.8), rgba(59, 130, 246, 0.35));
      pointer-events: none;
    }

    .panel-title {
      color: var(--muted);
      margin: 0;
      font-weight: 600;
      font-size: 0.95rem;
    }

    .facet-fields {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 0.55rem;
      padding-top: 0.05rem;
    }

    label {
      display: grid;
      gap: 0.28rem;
      font-size: 0.78rem;
      color: var(--muted);
      letter-spacing: 0.04em;
      text-transform: uppercase;
      font-weight: 600;
    }

    .field-full {
      grid-column: 1 / -1;
    }

    input[type="search"],
    select {
      width: 100%;
      padding: 0.72rem 0.8rem;
      border-radius: 10px;
      border: 1px solid var(--border);
      background: var(--input-bg);
      color: var(--text);
      font-size: 0.92rem;
      text-transform: none;
      font-weight: 500;
      letter-spacing: normal;
    }

    input[type="search"]::placeholder { color: var(--placeholder); }

    input[type="checkbox"] { accent-color: #60a5fa; }

    .toggle-row {
      display: grid;
      gap: 0.45rem;
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .inline-check {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      font-size: 0.78rem;
      color: var(--text);
      margin-top: 0;
      text-transform: none;
      letter-spacing: normal;
      font-weight: 500;
      padding: 0.46rem 0.5rem;
      border-radius: 8px;
      background: color-mix(in srgb, var(--panel-elevated) 82%, transparent);
      border: 1px solid var(--border);
    }

    .facet-reset {
      width: 100%;
      border: 1px solid var(--border-strong);
      background: var(--action-bg);
      color: var(--action-text);
      border-radius: 10px;
      padding: 0.58rem 0.72rem;
      font-size: 0.84rem;
      font-weight: 700;
      cursor: pointer;
      transition: background 160ms ease, border-color 160ms ease, color 160ms ease;
    }

    .facet-reset:hover {
      background: var(--action-bg-hover);
      border-color: color-mix(in srgb, var(--accent) 60%, transparent);
      color: var(--nav-active-text);
    }

    .hint {
      margin: 0;
      color: var(--muted);
      font-size: 0.82rem;
      line-height: 1.35;
    }

    .results-head {
      margin-top: 1.4rem;
      display: flex;
      justify-content: space-between;
      align-items: center;
    }

    .results-head h2 {
      margin: 0;
      font-size: 2rem;
      letter-spacing: 0.02em;
    }

    .results-head p {
      margin: 0;
      color: var(--muted);
      font-size: 0.9rem;
    }

    .results-actions {
      display: flex;
      align-items: center;
      gap: 0.7rem;
      flex-wrap: wrap;
      justify-content: flex-end;
    }

    .excel-export {
      border: 1px solid var(--border-strong);
      background: var(--action-bg);
      color: var(--action-text);
      border-radius: 10px;
      padding: 0.52rem 0.7rem;
      font-size: 0.82rem;
      font-weight: 700;
      text-decoration: none;
      transition: background 160ms ease, border-color 160ms ease, color 160ms ease;
    }

    .excel-export:hover {
      background: var(--action-bg-hover);
      border-color: color-mix(in srgb, var(--accent) 60%, transparent);
      color: var(--nav-active-text);
    }

    .skills-grid {
      margin-top: 0.85rem;
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 0.9rem;
      align-items: stretch;
    }

    .pagination {
      margin-top: 1rem;
      display: flex;
      align-items: center;
      justify-content: flex-end;
      gap: 0.6rem;
      flex-wrap: wrap;
    }

    .pagination p {
      margin: 0;
      color: var(--muted);
      font-size: 0.86rem;
      min-width: 140px;
      text-align: center;
    }

    .pagination button {
      border: 1px solid var(--border);
      background: color-mix(in srgb, var(--panel-elevated) 82%, transparent);
      color: var(--text);
      border-radius: 9px;
      padding: 0.45rem 0.75rem;
      font-size: 0.82rem;
      font-weight: 700;
      cursor: pointer;
    }

    .pagination button:disabled {
      opacity: 0.45;
      cursor: not-allowed;
    }

    .empty-results {
      margin: 0.9rem 0 0;
      padding: 0.8rem 0.95rem;
      border-radius: 10px;
      border: 1px dashed var(--border-strong);
      background: color-mix(in srgb, var(--panel) 82%, transparent);
      color: var(--muted);
      font-size: 0.9rem;
    }

    .skill-card {
      display: grid;
      gap: 0.6rem;
      padding: 0.95rem;
      border-radius: 12px;
      background: color-mix(in srgb, var(--panel-elevated) 80%, transparent);
      border: 1px solid var(--border);
      box-shadow: var(--shadow-soft);
      transition: transform 160ms ease, box-shadow 160ms ease;
      align-content: start;
      height: 100%;
    }

    .skill-card header {
      display: grid;
      gap: 0.35rem;
      min-height: 188px;
      align-content: start;
    }

    .skill-card:hover {
      transform: translateY(-1px);
      box-shadow: 0 18px 34px color-mix(in srgb, var(--text) 18%, transparent);
    }

    .repo {
      margin: 0;
      color: var(--muted);
      font-size: 0.9rem;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      font-weight: 600;
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
    }

    .skill-card h3 {
      margin: 0.1rem 0;
      font-size: 1.05rem;
      line-height: 1.2;
      min-height: calc(1.2em * 2);
    }

    .skill-card h3 a {
      display: -webkit-box;
      -webkit-line-clamp: 2;
      -webkit-box-orient: vertical;
      overflow: hidden;
      text-overflow: ellipsis;
    }

    .skill-card .desc {
      margin: 0;
      color: var(--muted);
      font-size: 0.9rem;
      line-height: 1.4;
      display: -webkit-box;
      -webkit-line-clamp: 5;
      -webkit-box-orient: vertical;
      overflow: hidden;
      text-overflow: ellipsis;
      min-height: calc(1.4em * 5);
    }

    .meta-row,
    .taxonomy-row,
    .badge-row,
    .asset-row {
      display: flex;
      gap: 0.35rem;
      flex-wrap: wrap;
      align-items: center;
      align-content: flex-start;
      min-height: 30px;
      max-height: 64px;
      overflow: hidden;
    }

    .meta-chip {
      padding: 0.2rem 0.7rem;
      border-radius: 999px;
      border: 1px solid var(--border);
      background: color-mix(in srgb, var(--panel-elevated) 80%, transparent);
      color: var(--text);
      font-size: 0.82rem;
      text-transform: lowercase;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      height: 30px;
      line-height: 1;
      white-space: nowrap;
    }

    .tag {
      padding: 0.2rem 0.7rem;
      border-radius: 999px;
      border: 1px solid var(--border);
      color: var(--text);
      font-size: 0.82rem;
      background: color-mix(in srgb, var(--panel-elevated) 80%, transparent);
      display: inline-flex;
      align-items: center;
      justify-content: center;
      height: 30px;
      line-height: 1;
      white-space: nowrap;
    }

    .tag.framework {
      background: color-mix(in srgb, var(--accent) 15%, transparent);
      color: var(--text);
      border-color: color-mix(in srgb, var(--accent) 45%, transparent);
    }

    .tag.type {
      background: color-mix(in srgb, var(--nav-active-bg) 62%, transparent);
      color: var(--text);
      border-color: var(--border-strong);
    }

    .tag--overflow {
      background: transparent;
      color: var(--muted);
      border-style: dashed;
      border-color: var(--border-strong);
      font-weight: 700;
    }

    .badge {
      padding: 0.2rem 0.7rem;
      border-radius: 999px;
      border: 1px solid var(--border);
      background: color-mix(in srgb, var(--panel-elevated) 82%, transparent);
      color: var(--text);
      font-size: 0.82rem;
      font-weight: 600;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      height: 30px;
      line-height: 1;
      white-space: nowrap;
    }

    .badge.featured {
      background: color-mix(in srgb, var(--success) 16%, transparent);
      border-color: color-mix(in srgb, var(--success) 50%, transparent);
      color: var(--text);
    }

    .badge--overflow {
      background: transparent;
      color: var(--muted);
      border-style: dashed;
      border-color: var(--border-strong);
      font-weight: 700;
    }

    .auto-badge {
      padding: 0.25rem 0.65rem;
      border-radius: 999px;
      border: 1px solid;
      color: var(--text);
      font-size: 0.8rem;
      font-weight: 600;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      height: 28px;
      line-height: 1;
      white-space: nowrap;
      gap: 0.3rem;
    }

    .auto-badge--overflow {
      background: transparent;
      color: var(--muted);
      border-style: dashed;
      border-color: var(--border-strong);
      font-weight: 700;
    }

    a {
      color: var(--accent);
    }

    a:hover {
      color: var(--link-hover);
    }

    @media (max-width: 1024px) {
      .hero {
        grid-template-columns: 1fr;
      }
      .facet-panel {
        width: 100%;
        justify-self: stretch;
      }
      .skills-grid {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }
    }

    @media (max-width: 720px) {
      .facet-fields {
        grid-template-columns: 1fr;
      }
      .toggle-row {
        grid-template-columns: 1fr;
      }
      .skills-grid {
        grid-template-columns: 1fr;
      }
    }

    @media (max-width: 640px) {
      .kpi-strip {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }
      .hero-addon {
        grid-template-columns: 1fr;
      }
    }

    @media (max-width: 480px) {
      .kpi-strip {
        grid-template-columns: 1fr;
      }
      .results-head {
        align-items: flex-start;
        gap: 0.5rem;
      }
      .pagination {
        justify-content: center;
      }

      .skill-card header {
        min-height: auto;
      }

      .skill-card .desc {
        -webkit-line-clamp: 4;
        min-height: calc(1.4em * 4);
      }
    }
  </style>

  <script>
    const grid = document.getElementById('skills-grid');
    const resultsCount = document.getElementById('results-count');
    const paginationStatus = document.getElementById('pagination-status');
    const paginationPrev = document.getElementById('pagination-prev');
    const paginationNext = document.getElementById('pagination-next');
    const paginationNav = document.getElementById('skills-pagination');
    const emptyState = document.getElementById('skills-empty-state');

    const PAGE_SIZE = 12;
    let currentPage = 1;
    let filteredCards: HTMLElement[] = [];

    function tokenize(value: string): string {
      return (value || '').toLowerCase().trim();
    }

    function getValue(id: string): string {
      const node = document.getElementById(id);
      if (!node) return '';
      if (node instanceof HTMLInputElement && node.type === 'checkbox') {
        return node.checked ? 'true' : '';
      }
      if (node instanceof HTMLInputElement || node instanceof HTMLSelectElement) {
        return tokenize(node.value || '');
      }
      return '';
    }

    function matchesFacet(
      card: HTMLElement,
      query: string,
      repo: string,
      framework: string,
      level: string,
      testType: string,
      status: string,
      examplesOnly: boolean,
      recommendedOnly: boolean
    ): boolean {
      const title = tokenize(card.dataset.title || '');
      const desc = tokenize(card.dataset.desc || '');
      const tags = tokenize(card.dataset.tags || '');
      const repoValue = tokenize(card.dataset.repo || '');
      const frameworks = tokenize(card.dataset.frameworks || '');
      const cardLevel = tokenize(card.dataset.level || '');
      const testTypes = tokenize(card.dataset.testTypes || '');
      const cardStatus = tokenize(card.dataset.status || '');
      const hasExamples = String(card.dataset.hasExamples || '').toLowerCase() === 'true';

      const searchTarget = `${title} ${desc} ${tags} ${frameworks} ${testTypes}`;

      const queryOk = !query || searchTarget.includes(query);
      const repoOk = !repo || repoValue === repo;
      const frameworkOk = !framework || frameworks.split(' ').includes(framework);
      const levelOk = !level || cardLevel === level;
      const testTypeOk = !testType || testTypes.split(' ').includes(testType);
      const statusOk = !status || cardStatus === status;
      const examplesOk = !examplesOnly || hasExamples;
      const recommendedOk = !recommendedOnly || cardStatus === 'recommended';

      return queryOk && repoOk && frameworkOk && levelOk && testTypeOk && statusOk && examplesOk && recommendedOk;
    }

    function filterSkills() {
      if (!grid) return;

      const query = getValue('skill-search');
      const repo = getValue('skill-repo');
      const framework = getValue('skill-framework');
      const level = getValue('skill-level');
      const testType = getValue('skill-test-type');
      const status = getValue('skill-status');
      const examplesOnly = getValue('skill-examples-only') === 'true';
      const recommendedOnly = getValue('skill-recommended-only') === 'true';

      const cards = Array.from(grid.children) as HTMLElement[];

      filteredCards = cards.filter((card) =>
        matchesFacet(card, query, repo, framework, level, testType, status, examplesOnly, recommendedOnly)
      );
      currentPage = 1;
      renderPage();
    }

    function renderPage() {
      if (!grid) return;

      const cards = Array.from(grid.children) as HTMLElement[];
      const hasResults = filteredCards.length > 0;

      if (!hasResults) {
        cards.forEach((card) => {
          card.style.display = 'none';
        });
        if (resultsCount) {
          resultsCount.textContent = '0 skills visibles';
        }
        if (paginationStatus) {
          paginationStatus.textContent = 'Sin resultados';
        }
        if (paginationPrev instanceof HTMLButtonElement) {
          paginationPrev.disabled = true;
        }
        if (paginationNext instanceof HTMLButtonElement) {
          paginationNext.disabled = true;
        }
        if (paginationNav) {
          paginationNav.setAttribute('hidden', 'hidden');
        }
        if (emptyState) {
          emptyState.removeAttribute('hidden');
        }
        return;
      }

      if (paginationNav) {
        paginationNav.removeAttribute('hidden');
      }
      if (emptyState) {
        emptyState.setAttribute('hidden', 'hidden');
      }

      const totalPages = Math.max(Math.ceil(filteredCards.length / PAGE_SIZE), 1);

      if (currentPage > totalPages) currentPage = totalPages;
      if (currentPage < 1) currentPage = 1;

      const start = (currentPage - 1) * PAGE_SIZE;
      const end = start + PAGE_SIZE;
      const visibleCards = new Set(filteredCards.slice(start, end));

      cards.forEach((card) => {
        card.style.display = visibleCards.has(card) ? 'grid' : 'none';
      });

      if (resultsCount) {
        resultsCount.textContent = `${filteredCards.length} skills visibles`;
      }
      if (paginationStatus) {
        paginationStatus.textContent = `Pagina ${currentPage} de ${totalPages}`;
      }
      if (paginationPrev instanceof HTMLButtonElement) {
        paginationPrev.disabled = currentPage <= 1;
      }
      if (paginationNext instanceof HTMLButtonElement) {
        paginationNext.disabled = currentPage >= totalPages;
      }
    }

    function goToPreviousPage() {
      currentPage -= 1;
      renderPage();
    }

    function goToNextPage() {
      currentPage += 1;
      renderPage();
    }

    function resetSkillFilters() {
      const search = document.getElementById('skill-search');
      const repo = document.getElementById('skill-repo');
      const framework = document.getElementById('skill-framework');
      const level = document.getElementById('skill-level');
      const testType = document.getElementById('skill-test-type');
      const status = document.getElementById('skill-status');
      const examples = document.getElementById('skill-examples-only');
      const recommended = document.getElementById('skill-recommended-only');

      if (search instanceof HTMLInputElement) search.value = '';
      if (repo instanceof HTMLSelectElement) repo.value = '';
      if (framework instanceof HTMLSelectElement) framework.value = '';
      if (level instanceof HTMLSelectElement) level.value = '';
      if (testType instanceof HTMLSelectElement) testType.value = '';
      if (status instanceof HTMLSelectElement) status.value = '';
      if (examples instanceof HTMLInputElement) examples.checked = false;
      if (recommended instanceof HTMLInputElement) recommended.checked = false;

      filterSkills();
    }

    filterSkills();

    // @ts-ignore
    window.filterSkills = filterSkills;
    // @ts-ignore
    window.resetSkillFilters = resetSkillFilters;
    // @ts-ignore
    window.goToPreviousPage = goToPreviousPage;
    // @ts-ignore
    window.goToNextPage = goToNextPage;
  </script>
</Layout>
