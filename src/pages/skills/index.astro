      font-size: 1.2rem;
    }

    .facet-panel {
      background: rgba(255, 255, 255, 0.03);
      border: 1px solid rgba(255, 255, 255, 0.08);
      border-radius: 14px;
      padding: 0.95rem;
      backdrop-filter: blur(6px);
      align-self: start;
      justify-self: end;
      display: grid;
      gap: 0.7rem;
      width: min(100%, 318px);
      position: relative;
      overflow: hidden;
    }

    .facet-panel::before {
      content: "";
      position: absolute;
      inset: 0 0 auto 0;
      height: 2px;
      background: linear-gradient(90deg, rgba(56, 189, 248, 0.8), rgba(59, 130, 246, 0.35));
      pointer-events: none;
    }

    .panel-title {
      color: #94a3b8;
      margin: 0;
      font-weight: 600;
      font-size: 0.95rem;
    }

    .facet-fields {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 0.55rem;
      padding-top: 0.05rem;
    }

    label {
      display: grid;
      gap: 0.28rem;
      font-size: 0.78rem;
      color: #cbd5e1;
      letter-spacing: 0.04em;
      text-transform: uppercase;
      font-weight: 600;
    }

    .field-full {
      grid-column: 1 / -1;
    }

    input[type="search"],
    select {
      width: 100%;
      padding: 0.72rem 0.8rem;
      border-radius: 10px;
      border: 1px solid rgba(255, 255, 255, 0.12);
      background: #0f172a;
      color: #e5e7eb;
      font-size: 0.92rem;
      text-transform: none;
      font-weight: 500;
      letter-spacing: normal;
    }

    input[type="search"]::placeholder { color: #64748b; }

    input[type="checkbox"] { accent-color: #60a5fa; }

    .toggle-row {
      display: grid;
      gap: 0.45rem;
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .inline-check {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      font-size: 0.78rem;
      color: #cbd5e1;
      margin-top: 0;
      text-transform: none;
      letter-spacing: normal;
      font-weight: 500;
      padding: 0.46rem 0.5rem;
      border-radius: 8px;
      background: rgba(15, 23, 42, 0.5);
      border: 1px solid rgba(255, 255, 255, 0.06);
    }

    .facet-reset {
      width: 100%;
      border: 1px solid rgba(125, 211, 252, 0.35);
      background: rgba(14, 116, 144, 0.15);
      color: #bae6fd;
      border-radius: 10px;
      padding: 0.58rem 0.72rem;
      font-size: 0.84rem;
      font-weight: 700;
      cursor: pointer;
      transition: background 160ms ease, border-color 160ms ease, color 160ms ease;
    }

    .facet-reset:hover {
      background: rgba(14, 116, 144, 0.26);
      border-color: rgba(125, 211, 252, 0.55);
      color: #e0f2fe;
    }

    .hint {
      margin: 0;
      color: #94a3b8;
      font-size: 0.82rem;
      line-height: 1.35;
    }

    .results-head {
      margin-top: 1.4rem;
      display: flex;
      justify-content: space-between;
      align-items: center;
    }

    .results-head h2 {
      margin: 0;
      font-size: 2rem;
      letter-spacing: 0.02em;
    }

    .results-head p {
      margin: 0;
      color: #94a3b8;
      font-size: 0.9rem;
    }

    .skills-grid {
      margin-top: 0.85rem;
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
      gap: 0.75rem;
    }

    .skill-card {
      display: grid;
      gap: 0.6rem;
      padding: 0.95rem;
      border-radius: 12px;
      background: rgba(255, 255, 255, 0.02);
      border: 1px solid rgba(255, 255, 255, 0.08);
      box-shadow: 0 8px 24px rgba(0, 0, 0, 0.22);
      transition: transform 160ms ease, box-shadow 160ms ease;
      align-content: start;
    }

    .skill-card:hover {
      transform: translateY(-1px);
      box-shadow: 0 14px 32px rgba(0, 0, 0, 0.32);
    }

    .repo {
      margin: 0;
      color: #94a3b8;
      font-size: 0.9rem;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      font-weight: 600;
    }

    h3 {
      margin: 0.1rem 0;
      font-size: 1.05rem;
      line-height: 1.2;
    }

    .desc {
      margin: 0;
      color: #cbd5e1;
      font-size: 0.9rem;
      line-height: 1.4;
    }

    .meta-row,
    .taxonomy-row,
    .badge-row,
    .asset-row {
      display: flex;
      gap: 0.35rem;
      flex-wrap: wrap;
      align-items: center;
      align-content: flex-start;
    }

    .meta-chip {
      padding: 0.2rem 0.7rem;
      border-radius: 999px;
      border: 1px solid rgba(255, 255, 255, 0.12);
      background: rgba(148, 163, 184, 0.1);
      color: #cbd5e1;
      font-size: 0.82rem;
      text-transform: lowercase;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      height: 30px;
      line-height: 1;
      white-space: nowrap;
    }

    .tag {
      padding: 0.2rem 0.7rem;
      border-radius: 999px;
      border: 1px solid rgba(255, 255, 255, 0.12);
      color: #cbd5e1;
      font-size: 0.82rem;
      background: rgba(148, 163, 184, 0.1);
      display: inline-flex;
      align-items: center;
      justify-content: center;
      height: 30px;
      line-height: 1;
      white-space: nowrap;
    }

    .tag.framework {
      background: rgba(56, 189, 248, 0.14);
      color: #bae6fd;
      border-color: rgba(56, 189, 248, 0.3);
    }

    .tag.type {
      background: rgba(168, 85, 247, 0.16);
      color: #ddd6fe;
      border-color: rgba(168, 85, 247, 0.3);
    }

    .badge {
      padding: 0.2rem 0.7rem;
      border-radius: 999px;
      border: 1px solid rgba(255, 255, 255, 0.14);
      background: rgba(148, 163, 184, 0.1);
      color: #cbd5e1;
      font-size: 0.82rem;
      font-weight: 600;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      height: 30px;
      line-height: 1;
      white-space: nowrap;
    }

    .badge.featured {
      background: rgba(16, 185, 129, 0.2);
      border-color: rgba(16, 185, 129, 0.45);
      color: #a7f3d0;
    }

    .auto-badge {
      padding: 0.25rem 0.65rem;
      border-radius: 999px;
      border: 1px solid;
      color: #cbd5e1;
      font-size: 0.8rem;
      font-weight: 600;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      height: 28px;
      line-height: 1;
      white-space: nowrap;
      gap: 0.3rem;
    }

    a {
      color: #e0f2fe;
    }

    a:hover {
      color: #67e8f9;
    }

    @media (max-width: 1024px) {
      .hero {
        grid-template-columns: 1fr;
      }
      .facet-panel {
        width: 100%;
        justify-self: stretch;
      }
    }

    @media (max-width: 760px) {
      .facet-fields {
        grid-template-columns: 1fr;
      }
      .toggle-row {
        grid-template-columns: 1fr;
      }
    }

    @media (max-width: 640px) {
      .kpi-strip {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }
      .hero-addon {
        grid-template-columns: 1fr;
      }
    }

    @media (max-width: 480px) {
      .kpi-strip {
        grid-template-columns: 1fr;
      }
    }
  </style>

  <script>
    const grid = document.getElementById('skills-grid');
    const resultsCount = document.getElementById('results-count');

    function tokenize(value: string): string {
      return (value || '').toLowerCase().trim();
    }

    function getValue(id: string): string {
      const node = document.getElementById(id);
      if (!node) return '';
      if (node instanceof HTMLInputElement && node.type === 'checkbox') {
        return node.checked ? 'true' : '';
      }
      if (node instanceof HTMLInputElement || node instanceof HTMLSelectElement) {
        return tokenize(node.value || '');
      }
      return '';
    }

    function matchesFacet(
      card: HTMLElement,
      query: string,
      repo: string,
      framework: string,
      level: string,
      testType: string,
      status: string,
      examplesOnly: boolean,
      recommendedOnly: boolean
    ): boolean {
      const title = tokenize(card.dataset.title || '');
      const desc = tokenize(card.dataset.desc || '');
      const tags = tokenize(card.dataset.tags || '');
      const repoValue = tokenize(card.dataset.repo || '');
      const frameworks = tokenize(card.dataset.frameworks || '');
      const cardLevel = tokenize(card.dataset.level || '');
      const testTypes = tokenize(card.dataset.testTypes || '');
      const cardStatus = tokenize(card.dataset.status || '');
      const hasExamples = String(card.dataset.hasExamples || '').toLowerCase() === 'true';

      const searchTarget = `${title} ${desc} ${tags} ${frameworks} ${testTypes}`;

      const queryOk = !query || searchTarget.includes(query);
      const repoOk = !repo || repoValue === repo;
      const frameworkOk = !framework || frameworks.split(' ').includes(framework);
      const levelOk = !level || cardLevel === level;
      const testTypeOk = !testType || testTypes.split(' ').includes(testType);
      const statusOk = !status || cardStatus === status;
      const examplesOk = !examplesOnly || hasExamples;
      const recommendedOk = !recommendedOnly || cardStatus === 'recommended';

      return queryOk && repoOk && frameworkOk && levelOk && testTypeOk && statusOk && examplesOk && recommendedOk;
    }

    function filterSkills() {
      if (!grid) return;

      const query = getValue('skill-search');
      const repo = getValue('skill-repo');
      const framework = getValue('skill-framework');
      const level = getValue('skill-level');
      const testType = getValue('skill-test-type');
      const status = getValue('skill-status');
      const examplesOnly = getValue('skill-examples-only') === 'true';
      const recommendedOnly = getValue('skill-recommended-only') === 'true';

      const cards = Array.from(grid.children) as HTMLElement[];
      let visibleCount = 0;

      cards.forEach((card) => {
        const asElement = card;
        const visible = matchesFacet(asElement, query, repo, framework, level, testType, status, examplesOnly, recommendedOnly);
        if (asElement instanceof HTMLElement) {
          asElement.style.display = visible ? 'grid' : 'none';
        }
        if (visible) visibleCount += 1;
      });

      if (resultsCount) {
        resultsCount.textContent = `${visibleCount} skills visibles`;
      }
    }

    function resetSkillFilters() {
      const search = document.getElementById('skill-search');
      const repo = document.getElementById('skill-repo');
      const framework = document.getElementById('skill-framework');
      const level = document.getElementById('skill-level');
      const testType = document.getElementById('skill-test-type');
      const status = document.getElementById('skill-status');
      const examples = document.getElementById('skill-examples-only');
      const recommended = document.getElementById('skill-recommended-only');

      if (search instanceof HTMLInputElement) search.value = '';
      if (repo instanceof HTMLSelectElement) repo.value = '';
      if (framework instanceof HTMLSelectElement) framework.value = '';
      if (level instanceof HTMLSelectElement) level.value = '';
      if (testType instanceof HTMLSelectElement) testType.value = '';
      if (status instanceof HTMLSelectElement) status.value = '';
      if (examples instanceof HTMLInputElement) examples.checked = false;
      if (recommended instanceof HTMLInputElement) recommended.checked = false;

      filterSkills();
    }

    // @ts-ignore
    window.filterSkills = filterSkills;
    // @ts-ignore
    window.resetSkillFilters = resetSkillFilters;
  </script>
</Layout>
