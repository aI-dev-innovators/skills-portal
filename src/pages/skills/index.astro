      gap: 0.55rem;
    }

    .insight-title {
      margin: 0;
      font-size: 0.8rem;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: #a5b4fc;
      font-weight: 700;
    }

    .insight-list {
      display: grid;
      gap: 0.4rem;
    }

    .insight-list p {
