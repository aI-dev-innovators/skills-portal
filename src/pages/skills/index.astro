---
import Layout from '../../layouts/Layout.astro';
import { readReposConfig } from '../../lib/config';
import { requireToken } from '../../lib/github.service';
import { collectAllSkills } from '../../lib/skill.service';
import { getBadgeDefinition } from '../../lib/badge.service';

requireToken();
const repos = readReposConfig();
const skills = (await collectAllSkills(repos)).sort((a, b) => a.title.localeCompare(b.title));

const repoOptions = Array.from(new Set(skills.map((s) => s.repoName || s.repoId))).sort();
const frameworkOptions = Array.from(new Set(skills.flatMap((s) => s.frameworks || []))).sort();
const levelOptions = Array.from(new Set(skills.map((s) => s.level))).sort();
const testTypeOptions = Array.from(new Set(skills.flatMap((s) => s.testTypes || []))).sort();
const statusOptions = Array.from(new Set(skills.map((s) => s.status))).sort();

const totalSkills = skills.length;
const skillsWithExamples = skills.filter((skill) => skill.hasExamples).length;
const skillsRecommended = skills.filter((skill) => skill.status === 'recommended').length;
const avgEstimatedTime =
  skills.reduce((acc, skill) => acc + (typeof skill.estimatedTime === 'number' ? skill.estimatedTime : 0), 0) /
  Math.max(skills.filter((skill) => typeof skill.estimatedTime === 'number').length, 1);
const recommendedRatio = totalSkills > 0 ? Math.round((skillsRecommended / totalSkills) * 100) : 0;
const examplesRatio = totalSkills > 0 ? Math.round((skillsWithExamples / totalSkills) * 100) : 0;
const frameworkDistribution = frameworkOptions
  .map((framework) => ({
    framework,
    count: skills.filter((skill) => (skill.frameworks || []).includes(framework)).length
  }))
  .sort((a, b) => b.count - a.count)
  .slice(0, 4);
---
<Layout title="Skills" description="Catálogo de skills con metadata enriquecida">
  <section class="hero">
    <div class="hero-copy">
      <p class="eyebrow">Skills Catalog</p>
      <h1>Explora skills por framework, nivel y tipo de prueba</h1>
      <p class="lede">
        Descubre skills listas para ejecutar con filtros facetados, badges de activos disponibles y señales editoriales de madurez.
      </p>
      <div class="kpi-strip">
        <article class="kpi-card">
          <span>Total skills</span>
          <strong>{totalSkills}</strong>
        </article>
        <article class="kpi-card">
          <span>Con ejemplos</span>
          <strong>{skillsWithExamples}</strong>
        </article>
        <article class="kpi-card">
          <span>Recommended</span>
          <strong>{skillsRecommended}</strong>
        </article>
        <article class="kpi-card">
          <span>Tiempo promedio</span>
          <strong>{Math.round(avgEstimatedTime || 0)} min</strong>
        </article>
      </div>

      <div class="hero-addon" aria-label="Resumen adicional del catálogo">
        <article class="insight-card">
          <p class="insight-title">Radar del catálogo</p>
          <div class="insight-list">
            <p><span>Cobertura recommended</span><strong>{recommendedRatio}%</strong></p>
            <p><span>Con ejemplos disponibles</span><strong>{examplesRatio}%</strong></p>
            <p><span>Tiempo estimado acumulado</span><strong>{Math.round((avgEstimatedTime || 0) * totalSkills)} min</strong></p>
          </div>
        </article>

        <article class="insight-card">
          <p class="insight-title">Frameworks con más skills</p>
          <div class="framework-stack">
            {frameworkDistribution.length === 0 ? (
              <p class="hint">Sin datos de frameworks por ahora.</p>
            ) : (
              frameworkDistribution.map((item) => (
                <div class="framework-row">
                  <span>{item.framework}</span>
                  <strong>{item.count}</strong>
                </div>
              ))
            )}
          </div>
          <div class="hero-links">
            <a href="/rankings">Ver rankings</a>
            <a href="/repos">Explorar repos</a>
          </div>
        </article>
      </div>
    </div>

    <aside class="facet-panel" aria-label="Filtros de skills">
      <p class="panel-title">Filtrar skills</p>
      <div class="facet-fields">
        <label class="field field-full">
          Buscar
          <input id="skill-search" type="search" placeholder="Ej. angular, jest, coverage" oninput="filterSkills()" />
        </label>
        <label class="field">
          Repositorio
          <select id="skill-repo" onchange="filterSkills()">
            <option value="">Todos</option>
            {repoOptions.map((repo) => (
              <option value={repo.toLowerCase()}>{repo}</option>
            ))}
          </select>
        </label>
        <label class="field">
          Framework
          <select id="skill-framework" onchange="filterSkills()">
            <option value="">Todos</option>
            {frameworkOptions.map((framework) => (
              <option value={framework}>{framework}</option>
            ))}
          </select>
        </label>
        <label class="field">
          Nivel
          <select id="skill-level" onchange="filterSkills()">
            <option value="">Todos</option>
            {levelOptions.map((level) => (
              <option value={level}>{level}</option>
            ))}
          </select>
        </label>
        <label class="field">
          Tipo de test
          <select id="skill-test-type" onchange="filterSkills()">
            <option value="">Todos</option>
            {testTypeOptions.map((testType) => (
              <option value={testType}>{testType}</option>
            ))}
          </select>
        </label>
        <label class="field field-full">
          Estado
          <select id="skill-status" onchange="filterSkills()">
            <option value="">Todos</option>
            {statusOptions.map((status) => (
              <option value={status}>{status}</option>
            ))}
          </select>
        </label>
      </div>
      <div class="toggle-row">
        <label class="inline-check">
          <input id="skill-examples-only" type="checkbox" onchange="filterSkills()" />
          Solo con examples
        </label>
        <label class="inline-check">
          <input id="skill-recommended-only" type="checkbox" onchange="filterSkills()" />
          Solo recommended
        </label>
      </div>
      <button class="facet-reset" type="button" onclick="resetSkillFilters()">Limpiar filtros</button>
      <p class="hint">El filtrado se ejecuta en cliente para respuesta inmediata.</p>
    </aside>
  </section>

  <section class="results-head">
    <h2>Resultados</h2>
    <p id="results-count">{totalSkills} skills visibles</p>
  </section>

  <section>
    {skills.length === 0 ? (
      <p class="hint">No hay skills registradas.</p>
    ) : (
      <div class="skills-grid" id="skills-grid">
        {skills.map((skill) => (
          <article
            class="skill-card"
            data-title={skill.title.toLowerCase()}
            data-desc={skill.description.toLowerCase()}
            data-tags={(skill.tags || []).join(' ').toLowerCase()}
            data-frameworks={(skill.frameworks || []).join(' ').toLowerCase()}
            data-level={(skill.level || '').toLowerCase()}
            data-test-types={(skill.testTypes || []).join(' ').toLowerCase()}
            data-status={(skill.status || '').toLowerCase()}
            data-repo={(skill.repoName || skill.repoId || '').toLowerCase()}
            data-has-examples={skill.hasExamples ? 'true' : 'false'}
          >
            <header>
              <p class="repo">{skill.repoName || skill.repoId}</p>
              <h3><a href={`/skills/${skill.id}/`}>{skill.title}</a></h3>
              <p class="desc">{skill.description}</p>
            </header>

            <div class="meta-row">
              <span class="meta-chip">{skill.level}</span>
              <span class="meta-chip">{skill.status}</span>
              {typeof skill.estimatedTime === 'number' && <span class="meta-chip">{skill.estimatedTime} min</span>}
              <span class="meta-chip">v{skill.version}</span>
            </div>

            <div class="taxonomy-row">
              {(skill.frameworks || []).map((framework) => (
                <span class="tag framework">{framework}</span>
              ))}
              {(skill.testTypes || []).map((testType) => (
                <span class="tag type">{testType}</span>
              ))}
            </div>

            {(skill.badges || []).length > 0 && (
              <div class="badge-row">
                {(skill.badges || []).map((badgeType) => {
                  const badgeDef = getBadgeDefinition(badgeType);
                  const colorMap = {
                    'green': '#10b981',
                    'blue': '#3b82f6',
                    'purple': '#a855f7',
                    'amber': '#f59e0b',
                    'pink': '#ec4899'
                  };
                  const badgeColor = colorMap[badgeDef.color as keyof typeof colorMap];
                  return (
                    <span 
                      class="auto-badge"
                      title={badgeDef.tooltip}
                      style={`background: ${badgeColor}20; border-color: ${badgeColor}50; color: ${badgeColor}`}
                    >
                      {badgeDef.icon} {badgeDef.label}
                    </span>
                  );
                })}
              </div>
            )}

            <div class="asset-row">
              {skill.hasExamples && <span class="badge">Examples</span>}
              {skill.hasTemplates && <span class="badge">Templates</span>}
              {skill.hasEvals && <span class="badge">Evals</span>}
              {skill.hasScripts && <span class="badge">Scripts</span>}
              {skill.status === 'recommended' && <span class="badge featured">Recommended</span>}
            </div>
          </article>
        ))}
      </div>
    )}
  </section>

  <style>
    :global(body) {
      background: #07090f;
      color: #e5e7eb;
      font-family: "Space Grotesk", "Public Sans", system-ui, -apple-system, sans-serif;
    }

    :global(.site-header), :global(.site-footer) {
      background: #0c101a;
      border-color: rgba(255, 255, 255, 0.06);
    }

    :global(.site-header .brand) { color: #e5e7eb; }
    :global(.site-header nav a) { color: #cbd5e1; }
    :global(.site-header nav a:hover) { color: #e0f2fe; }
    :global(main) { padding: 2rem 0 3rem; }

    .hero {
      display: grid;
      grid-template-columns: 1.85fr minmax(280px, 340px);
      gap: 1.5rem;
      align-items: start;
      padding: 2rem;
      border: 1px solid rgba(255, 255, 255, 0.08);
      border-radius: 18px;
      background:
        radial-gradient(circle at 20% 20%, rgba(56, 189, 248, 0.12), transparent 35%),
        radial-gradient(circle at 80% 0%, rgba(168, 85, 247, 0.16), transparent 32%),
        #0c101a;
      box-shadow: 0 20px 60px rgba(0, 0, 0, 0.45);
    }

    .eyebrow {
      text-transform: uppercase;
      letter-spacing: 0.12em;
      font-size: 0.8rem;
      color: #a5b4fc;
      margin: 0 0 0.4rem;
    }

    h1 {
      margin: 0;
      font-size: clamp(1.8rem, 3vw, 2.4rem);
      letter-spacing: -0.02em;
    }

    .lede {
      color: #cbd5e1;
      margin: 0.6rem 0 1.2rem;
      max-width: 720px;
      line-height: 1.5;
    }

    .kpi-strip {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
      gap: 1rem;
    }

    .hero-addon {
      margin-top: 1rem;
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 0.85rem;
    }

    .insight-card {
      border: 1px solid rgba(255, 255, 255, 0.08);
      background: rgba(15, 23, 42, 0.5);
      border-radius: 12px;
      padding: 0.75rem 0.85rem;
