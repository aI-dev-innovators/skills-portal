---
import Layout from '../../layouts/Layout.astro';
import { readReposConfig } from '../../lib/config';
import { requireToken } from '../../lib/github.service';
import { collectAllSkills } from '../../lib/skill.service';

requireToken();
const repos = readReposConfig();
const skills = (await collectAllSkills(repos)).sort((a, b) => a.title.localeCompare(b.title));

const repoOptions = Array.from(new Set(skills.map((s) => s.repoName || s.repoId))).sort();
const frameworkOptions = Array.from(new Set(skills.flatMap((s) => s.frameworks || []))).sort();
const levelOptions = Array.from(new Set(skills.map((s) => s.level))).sort();
const testTypeOptions = Array.from(new Set(skills.flatMap((s) => s.testTypes || []))).sort();
const statusOptions = Array.from(new Set(skills.map((s) => s.status))).sort();

const totalSkills = skills.length;
const skillsWithExamples = skills.filter((skill) => skill.hasExamples).length;
const skillsRecommended = skills.filter((skill) => skill.status === 'recommended').length;
const avgEstimatedTime =
  skills.reduce((acc, skill) => acc + (typeof skill.estimatedTime === 'number' ? skill.estimatedTime : 0), 0) /
  Math.max(skills.filter((skill) => typeof skill.estimatedTime === 'number').length, 1);
---
<Layout title="Skills" description="Catálogo de skills con metadata enriquecida">
  <section class="hero">
    <div class="hero-copy">
      <p class="eyebrow">Skills Catalog</p>
      <h1>Explora skills por framework, nivel y tipo de prueba</h1>
      <p class="lede">
        Descubre skills listas para ejecutar con filtros facetados, badges de activos disponibles y señales editoriales de madurez.
      </p>
      <div class="kpi-strip">
        <article class="kpi-card">
          <span>Total skills</span>
          <strong>{totalSkills}</strong>
        </article>
        <article class="kpi-card">
          <span>Con ejemplos</span>
          <strong>{skillsWithExamples}</strong>
        </article>
        <article class="kpi-card">
          <span>Recommended</span>
          <strong>{skillsRecommended}</strong>
        </article>
        <article class="kpi-card">
          <span>Tiempo promedio</span>
          <strong>{Math.round(avgEstimatedTime || 0)} min</strong>
        </article>
      </div>
    </div>

    <aside class="facet-panel" aria-label="Filtros de skills">
      <p class="panel-title">Filtrar skills</p>
      <label>
        Buscar
        <input id="skill-search" type="search" placeholder="Ej. angular, jest, coverage" oninput="filterSkills()" />
      </label>
      <label>
        Repositorio
        <select id="skill-repo" onchange="filterSkills()">
          <option value="">Todos</option>
          {repoOptions.map((repo) => (
            <option value={repo.toLowerCase()}>{repo}</option>
          ))}
        </select>
      </label>
      <label>
        Framework
        <select id="skill-framework" onchange="filterSkills()">
          <option value="">Todos</option>
          {frameworkOptions.map((framework) => (
            <option value={framework}>{framework}</option>
          ))}
        </select>
      </label>
      <label>
        Nivel
        <select id="skill-level" onchange="filterSkills()">
          <option value="">Todos</option>
          {levelOptions.map((level) => (
            <option value={level}>{level}</option>
          ))}
        </select>
      </label>
      <label>
        Tipo de test
        <select id="skill-test-type" onchange="filterSkills()">
          <option value="">Todos</option>
          {testTypeOptions.map((testType) => (
            <option value={testType}>{testType}</option>
          ))}
        </select>
      </label>
      <label>
        Estado
        <select id="skill-status" onchange="filterSkills()">
          <option value="">Todos</option>
          {statusOptions.map((status) => (
            <option value={status}>{status}</option>
          ))}
        </select>
      </label>
      <label class="inline-check">
        <input id="skill-examples-only" type="checkbox" onchange="filterSkills()" />
        Solo con examples
      </label>
      <label class="inline-check">
        <input id="skill-recommended-only" type="checkbox" onchange="filterSkills()" />
        Solo recommended
      </label>
      <p class="hint">El filtrado se ejecuta en cliente para respuesta inmediata.</p>
    </aside>
  </section>

  <section class="results-head">
    <h2>Resultados</h2>
    <p id="results-count">{totalSkills} skills visibles</p>
  </section>

  <section>
    {skills.length === 0 ? (
      <p class="hint">No hay skills registradas.</p>
    ) : (
      <div class="skills-grid" id="skills-grid">
        {skills.map((skill) => (
          <article
            class="skill-card"
            data-title={skill.title.toLowerCase()}
            data-desc={skill.description.toLowerCase()}
            data-tags={(skill.tags || []).join(' ').toLowerCase()}
            data-frameworks={(skill.frameworks || []).join(' ').toLowerCase()}
            data-level={(skill.level || '').toLowerCase()}
            data-test-types={(skill.testTypes || []).join(' ').toLowerCase()}
            data-status={(skill.status || '').toLowerCase()}
            data-repo={(skill.repoName || skill.repoId || '').toLowerCase()}
            data-has-examples={skill.hasExamples ? 'true' : 'false'}
          >
            <header>
              <p class="repo">{skill.repoName || skill.repoId}</p>
              <h3><a href={`/skills/${skill.id}`}>{skill.title}</a></h3>
              <p class="desc">{skill.description}</p>
            </header>

            <div class="meta-row">
              <span class="meta-chip">{skill.level}</span>
              <span class="meta-chip">{skill.status}</span>
              {typeof skill.estimatedTime === 'number' && <span class="meta-chip">{skill.estimatedTime} min</span>}
              <span class="meta-chip">v{skill.version}</span>
            </div>

            <div class="taxonomy-row">
              {(skill.frameworks || []).map((framework) => (
                <span class="tag framework">{framework}</span>
              ))}
              {(skill.testTypes || []).map((testType) => (
                <span class="tag type">{testType}</span>
              ))}
            </div>

            <div class="asset-row">
              {skill.hasExamples && <span class="badge">Examples</span>}
              {skill.hasTemplates && <span class="badge">Templates</span>}
              {skill.hasEvals && <span class="badge">Evals</span>}
              {skill.hasScripts && <span class="badge">Scripts</span>}
              {skill.status === 'recommended' && <span class="badge featured">Recommended</span>}
            </div>
          </article>
        ))}
      </div>
    )}
  </section>

  <style>
    :global(body) {
      background: #07090f;
      color: #e5e7eb;
      font-family: "Space Grotesk", "Public Sans", system-ui, -apple-system, sans-serif;
    }

    :global(.site-header), :global(.site-footer) {
      background: #0c101a;
      border-color: rgba(255, 255, 255, 0.06);
    }

    :global(.site-header .brand) { color: #e5e7eb; }
    :global(.site-header nav a) { color: #cbd5e1; }
    :global(.site-header nav a:hover) { color: #e0f2fe; }
    :global(main) { padding: 2rem 0 3rem; }

    .hero {
      display: grid;
      grid-template-columns: 2fr 1fr;
      gap: 1.5rem;
      align-items: start;
      padding: 2rem;
      border: 1px solid rgba(255, 255, 255, 0.08);
      border-radius: 18px;
      background:
        radial-gradient(circle at 20% 20%, rgba(56, 189, 248, 0.12), transparent 35%),
        radial-gradient(circle at 80% 0%, rgba(168, 85, 247, 0.16), transparent 32%),
        #0c101a;
      box-shadow: 0 20px 60px rgba(0, 0, 0, 0.45);
    }

    .eyebrow {
      text-transform: uppercase;
      letter-spacing: 0.12em;
      font-size: 0.8rem;
      color: #a5b4fc;
      margin: 0 0 0.4rem;
    }

    h1 {
      margin: 0;
      font-size: clamp(1.8rem, 3vw, 2.4rem);
      letter-spacing: -0.02em;
    }

    .lede {
      color: #cbd5e1;
      margin: 0.6rem 0 1.2rem;
      max-width: 720px;
      line-height: 1.5;
    }

    .kpi-strip {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
      gap: 1rem;
    }

    .kpi-card {
      background: rgba(255, 255, 255, 0.02);
      border: 1px solid rgba(255, 255, 255, 0.08);
      border-radius: 12px;
      padding: 0.9rem 1rem;
      display: grid;
      gap: 0.2rem;
    }

    .kpi-card span {
      color: #94a3b8;
      font-size: 0.9rem;
      text-transform: uppercase;
      letter-spacing: 0.06em;
    }

    .kpi-card strong {
      font-weight: 700;
      font-size: 1.2rem;
    }

    .facet-panel {
      background: rgba(255, 255, 255, 0.03);
      border: 1px solid rgba(255, 255, 255, 0.08);
      border-radius: 12px;
      padding: 1rem;
      backdrop-filter: blur(6px);
      align-self: center;
      display: grid;
      gap: 0.55rem;
    }

    .panel-title {
      color: #94a3b8;
      margin: 0 0 0.4rem;
      font-weight: 600;
    }

    label {
      display: grid;
      gap: 0.28rem;
      font-size: 0.84rem;
      color: #cbd5e1;
    }

    input[type="search"],
    select {
      width: 100%;
      padding: 0.9rem 1rem;
      border-radius: 10px;
      border: 1px solid rgba(255, 255, 255, 0.12);
      background: #0f172a;
      color: #e5e7eb;
      font-size: 1rem;
    }

    input[type="search"]::placeholder { color: #64748b; }

    input[type="checkbox"] { accent-color: #60a5fa; }

    .inline-check {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      font-size: 0.85rem;
      color: #cbd5e1;
      margin-top: 0.1rem;
    }

    .hint {
      margin: 0;
      color: #94a3b8;
      font-size: 0.9rem;
    }

    .results-head {
      margin-top: 1.4rem;
      display: flex;
      justify-content: space-between;
      align-items: center;
    }

    .results-head h2 {
      margin: 0;
      font-size: 2rem;
      letter-spacing: 0.02em;
    }

    .results-head p {
      margin: 0;
      color: #94a3b8;
      font-size: 0.9rem;
    }

    .skills-grid {
      margin-top: 0.85rem;
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
      gap: 0.75rem;
    }

    .skill-card {
      display: grid;
      gap: 0.6rem;
      padding: 0.95rem;
      border-radius: 12px;
      background: rgba(255, 255, 255, 0.02);
      border: 1px solid rgba(255, 255, 255, 0.08);
      box-shadow: 0 8px 24px rgba(0, 0, 0, 0.22);
      transition: transform 160ms ease, box-shadow 160ms ease;
      align-content: start;
    }

    .skill-card:hover {
      transform: translateY(-1px);
      box-shadow: 0 14px 32px rgba(0, 0, 0, 0.32);
    }

    .repo {
      margin: 0;
      color: #94a3b8;
      font-size: 0.9rem;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      font-weight: 600;
    }

    h3 {
      margin: 0.1rem 0;
      font-size: 1.05rem;
      line-height: 1.2;
    }

    .desc {
      margin: 0;
      color: #cbd5e1;
      font-size: 0.9rem;
      line-height: 1.4;
    }

    .meta-row,
    .taxonomy-row,
    .asset-row {
      display: flex;
      gap: 0.35rem;
      flex-wrap: wrap;
      align-items: center;
      align-content: flex-start;
    }

    .meta-chip {
      padding: 0.2rem 0.7rem;
      border-radius: 999px;
      border: 1px solid rgba(255, 255, 255, 0.12);
      background: rgba(148, 163, 184, 0.1);
      color: #cbd5e1;
      font-size: 0.82rem;
      text-transform: lowercase;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      height: 30px;
      line-height: 1;
      white-space: nowrap;
    }

    .tag {
      padding: 0.2rem 0.7rem;
      border-radius: 999px;
      border: 1px solid rgba(255, 255, 255, 0.12);
      color: #cbd5e1;
      font-size: 0.82rem;
      background: rgba(148, 163, 184, 0.1);
      display: inline-flex;
      align-items: center;
      justify-content: center;
      height: 30px;
      line-height: 1;
      white-space: nowrap;
    }

    .tag.framework {
      background: rgba(56, 189, 248, 0.14);
      color: #bae6fd;
      border-color: rgba(56, 189, 248, 0.3);
    }

    .tag.type {
      background: rgba(168, 85, 247, 0.16);
      color: #ddd6fe;
      border-color: rgba(168, 85, 247, 0.3);
    }

    .badge {
      padding: 0.2rem 0.7rem;
      border-radius: 999px;
      border: 1px solid rgba(255, 255, 255, 0.14);
      background: rgba(148, 163, 184, 0.1);
      color: #cbd5e1;
      font-size: 0.82rem;
      font-weight: 600;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      height: 30px;
      line-height: 1;
      white-space: nowrap;
    }

    .badge.featured {
      background: rgba(16, 185, 129, 0.2);
      border-color: rgba(16, 185, 129, 0.45);
      color: #a7f3d0;
    }

    a {
      color: #e0f2fe;
    }

    a:hover {
      color: #67e8f9;
    }

    @media (max-width: 1024px) {
      .hero {
        grid-template-columns: 1fr;
      }
    }

    @media (max-width: 640px) {
      .kpi-strip {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }
    }

    @media (max-width: 480px) {
      .kpi-strip {
        grid-template-columns: 1fr;
      }
    }
  </style>

  <script>
    const grid = document.getElementById('skills-grid');
    const resultsCount = document.getElementById('results-count');

    function tokenize(value: string): string {
      return (value || '').toLowerCase().trim();
    }

    function getValue(id: string): string {
      const node = document.getElementById(id);
      if (!node) return '';
      if (node instanceof HTMLInputElement && node.type === 'checkbox') {
        return node.checked ? 'true' : '';
      }
      if (node instanceof HTMLInputElement || node instanceof HTMLSelectElement) {
        return tokenize(node.value || '');
      }
      return '';
    }

    function matchesFacet(
      card: HTMLElement,
      query: string,
      repo: string,
      framework: string,
      level: string,
      testType: string,
      status: string,
      examplesOnly: boolean,
      recommendedOnly: boolean
    ): boolean {
      const title = tokenize(card.dataset.title || '');
      const desc = tokenize(card.dataset.desc || '');
      const tags = tokenize(card.dataset.tags || '');
      const repoValue = tokenize(card.dataset.repo || '');
      const frameworks = tokenize(card.dataset.frameworks || '');
      const cardLevel = tokenize(card.dataset.level || '');
      const testTypes = tokenize(card.dataset.testTypes || '');
      const cardStatus = tokenize(card.dataset.status || '');
      const hasExamples = String(card.dataset.hasExamples || '').toLowerCase() === 'true';

      const searchTarget = `${title} ${desc} ${tags} ${frameworks} ${testTypes}`;

      const queryOk = !query || searchTarget.includes(query);
      const repoOk = !repo || repoValue === repo;
      const frameworkOk = !framework || frameworks.split(' ').includes(framework);
      const levelOk = !level || cardLevel === level;
      const testTypeOk = !testType || testTypes.split(' ').includes(testType);
      const statusOk = !status || cardStatus === status;
      const examplesOk = !examplesOnly || hasExamples;
      const recommendedOk = !recommendedOnly || cardStatus === 'recommended';

      return queryOk && repoOk && frameworkOk && levelOk && testTypeOk && statusOk && examplesOk && recommendedOk;
    }

    function filterSkills() {
      if (!grid) return;

      const query = getValue('skill-search');
      const repo = getValue('skill-repo');
      const framework = getValue('skill-framework');
      const level = getValue('skill-level');
      const testType = getValue('skill-test-type');
      const status = getValue('skill-status');
      const examplesOnly = getValue('skill-examples-only') === 'true';
      const recommendedOnly = getValue('skill-recommended-only') === 'true';

      const cards = Array.from(grid.children) as HTMLElement[];
      let visibleCount = 0;

      cards.forEach((card) => {
        const asElement = card;
        const visible = matchesFacet(asElement, query, repo, framework, level, testType, status, examplesOnly, recommendedOnly);
        if (asElement instanceof HTMLElement) {
          asElement.style.display = visible ? 'grid' : 'none';
        }
        if (visible) visibleCount += 1;
      });

      if (resultsCount) {
        resultsCount.textContent = `${visibleCount} skills visibles`;
      }
    }

    // @ts-ignore
    window.filterSkills = filterSkills;
  </script>
</Layout>
