---
import Layout from '../../layouts/Layout.astro';
import path from 'node:path';
import { readReposConfig } from '../../lib/config';
import { fetchRepositoryContent, fetchRepositoryFileText, requireToken } from '../../lib/github.service';
import { collectAllSkills, fetchSkillBySlug } from '../../lib/skill.service';
import { mdToHtml } from '../../lib/markdown';
import { getRepoContext } from '../../lib/repo.service';

export async function getStaticPaths() {
  requireToken();
  const repos = readReposConfig();
  const skills = await collectAllSkills(repos);
  return skills.map((skill) => ({ params: { slug: skill.id } }));
}

const { slug } = Astro.params;
if (!slug) throw new Error('Slug requerido');

requireToken();
const repos = readReposConfig();
// Busca el skill en los repos registrados y trae su markdown.
const skill = await fetchSkillBySlug(repos, slug);
const allSkills = await collectAllSkills(repos);

if (!skill) {
  return Astro.redirect('/skills');
}

const recommendationCatalog = allSkills.map((entry) => ({
  id: entry.id,
  title: entry.title,
  url: entry.url,
  description: entry.description,
  repoName: entry.repoName,
  frameworks: entry.frameworks,
  testTypes: entry.testTypes,
  tags: entry.tags,
  score: entry.score
}));

const sourceRepo = repos.find((repo) => repo.id === skill.repoId) || null;
const repoContext = sourceRepo ? await getRepoContext(sourceRepo) : null;

const installSingleSkillCommand = sourceRepo
  ? `private-skills add ${sourceRepo.repoUrl} --skill-name ${skill.name}`
  : null;

const repoWebUrl = repoContext
  ? `https://github.com/${repoContext.slug.owner}/${repoContext.slug.name}`
  : null;

let skillReadmeOrSkillContent = skill.content;
let skillReadmeOrSkillPath = skill.sourcePath;
let skillReadmeSourceLabel = 'SKILL.md';

if (repoContext) {
  const branch = repoContext.defaultBranch;
  const skillDir = path.posix.dirname(skill.sourcePath);
  const dirContent = await fetchRepositoryContent(repoContext.slug.owner, repoContext.slug.name, skillDir, branch);

  if (Array.isArray(dirContent)) {
    const readmeEntry = dirContent.find(
      (entry) => entry.type === 'file' && entry.name.toLowerCase() === 'readme.md'
    );

    if (readmeEntry) {
      const readmeContent = await fetchRepositoryFileText(
        repoContext.slug.owner,
        repoContext.slug.name,
        readmeEntry.path,
        branch
      );

      if (readmeContent) {
        skillReadmeOrSkillContent = readmeContent;
        skillReadmeOrSkillPath = readmeEntry.path;
        skillReadmeSourceLabel = 'README.md';
      }
    }
  }
}

const skillDocHtml = mdToHtml(skillReadmeOrSkillContent);
const skillFileWebUrl = repoContext
  ? `${repoWebUrl}/blob/${repoContext.defaultBranch}/${skillReadmeOrSkillPath}`
  : null;
---
<Layout title={skill.title} description={skill.description}>
  <section class="skill-hero">
    <div class="skill-hero-main">
      <p class="badge">{skill.repoName || skill.repoId || 'Repositorio'}</p>
      <h1>{skill.title}</h1>
      <p>{skill.description}</p>
      {skill.tags.length > 0 && (
        <div class="tag-wrap">
          {skill.tags.map((tag) => (
            <span class="badge">{tag}</span>
          ))}
        </div>
      )}
      <div class="meta-pills">
        <span class="meta-pill"><strong>Nivel</strong>{skill.level}</span>
        <span class="meta-pill"><strong>Estado</strong>{skill.status}</span>
        <span class="meta-pill"><strong>Version</strong>{skill.version}</span>
        {typeof skill.estimatedTime === 'number' && (
          <span class="meta-pill"><strong>Tiempo</strong>{skill.estimatedTime} min</span>
        )}
        {skill.frameworks.length > 0 && (
          <span class="meta-pill"><strong>Frameworks</strong>{skill.frameworks.join(', ')}</span>
        )}
        {skill.testTypes.length > 0 && (
          <span class="meta-pill"><strong>Tests</strong>{skill.testTypes.join(', ')}</span>
        )}
      </div>
    </div>
    <aside class="skill-hero-panel">
      {(skill.hasExamples || skill.hasTemplates || skill.hasEvals || skill.hasScripts) && (
        <div class="asset-wrap">
          {skill.hasExamples && <span class="asset">Examples</span>}
          {skill.hasTemplates && <span class="asset">Templates</span>}
          {skill.hasEvals && <span class="asset">Evals</span>}
          {skill.hasScripts && <span class="asset">Scripts</span>}
        </div>
      )}
      {installSingleSkillCommand && (
        <div class="cmd-wrap cmd-install-wrap">
          <strong>Instalar solo esta skill</strong>
          <div class="install-command-box">
            <code id="install-skill-command">{installSingleSkillCommand}</code>
            <button
              type="button"
              class="copy-command-button"
              id="copy-install-command"
              data-command={installSingleSkillCommand}
              aria-label="Copiar comando de instalación"
            >
              Copiar
            </button>
          </div>
          <p class="copy-command-meta" id="copy-install-command-meta">Copia el comando y ejecútalo en tu terminal.</p>
        </div>
      )}
      {(repoWebUrl || skillFileWebUrl) && (
        <div class="link-wrap">
          <strong>Repositorio</strong>
          <div class="repo-links">
            {repoWebUrl && (
              <a href={repoWebUrl} target="_blank" rel="noreferrer noopener">Ver repositorio</a>
            )}
            {skillFileWebUrl && (
              <a href={skillFileWebUrl} target="_blank" rel="noreferrer noopener">Ver skill</a>
            )}
          </div>
        </div>
      )}
      {skill.recommendedCommands.length > 0 && (
        <details class="cmd-wrap cmd-details">
          <summary>Comandos sugeridos</summary>
          <ul>
            {skill.recommendedCommands.map((command) => (
              <li><code>{command}</code></li>
            ))}
          </ul>
        </details>
      )}
    </aside>
  </section>
  <section class="skill-doc-head">
    <p class="badge">Contenido de skill</p>
    <h2>{skillReadmeSourceLabel}</h2>
    <p>Se muestra {skillReadmeSourceLabel === 'README.md' ? 'README.md' : 'SKILL.md'} del repositorio.</p>
  </section>
  <section class="telemetry-panel">
    <strong>¿Te sirvió esta skill?</strong>
    <div class="vote-row" id="helpful-vote-actions">
      <button type="button" class="vote-button" data-vote="helpful">Sí</button>
      <button type="button" class="vote-button" data-vote="not-helpful">No</button>
    </div>
    <p class="telemetry-meta" id="skill-view-meta">Sin vistas registradas todavía.</p>
    <p class="telemetry-meta" id="skill-vote-meta">Aún no hay votos.</p>
  </section>
  <div class="skill-content" set:html={skillDocHtml}></div>
  <section class="recommend-section">
    <div class="recommend-head">
      <p class="badge">Personalización ligera</p>
      <h2>Relacionadas para ti</h2>
    </div>
    <div id="recommended-skills-detail" class="recommend-grid">
      <p class="recommend-empty">Explora más skills para mejorar estas sugerencias.</p>
    </div>
  </section>

  <style>
    .skill-hero {
      display: flex;
      align-items: flex-start;
      justify-content: space-between;
      gap: 0.95rem;
      padding: 1.1rem;
      border: 1px solid rgba(255, 255, 255, 0.08);
      border-radius: 16px;
      background: radial-gradient(circle at 15% 18%, rgba(56, 189, 248, 0.12), transparent 43%),
        radial-gradient(circle at 86% 2%, rgba(14, 116, 144, 0.18), transparent 36%),
        var(--panel);
      box-shadow: var(--shadow);
      margin-bottom: 1rem;
    }
    .skill-hero-main {
      min-width: 0;
      display: grid;
      gap: 0.45rem;
    }
    .skill-hero h1 {
      margin: 0.1rem 0;
      letter-spacing: -0.01em;
      line-height: 1.05;
    }
    .skill-hero p {
      margin: 0;
      color: var(--muted);
    }
    .skill-hero .badge {
      margin: 0 0 0.4rem;
      background: rgba(148, 163, 184, 0.12);
      border: 1px solid rgba(255, 255, 255, 0.12);
      color: var(--text);
    }
    .skill-hero .badge + .badge { margin-left: 0.3rem; }
    .tag-wrap { margin-top: 0.45rem; }
    .meta-pills {
      margin-top: 0.15rem;
      display: flex;
      flex-wrap: wrap;
      gap: 0.45rem;
    }
    .meta-pill {
      display: inline-flex;
      gap: 0.4rem;
      align-items: center;
      border-radius: 999px;
      padding: 0.24rem 0.6rem;
      border: 1px solid rgba(255, 255, 255, 0.15);
      background: rgba(15, 23, 42, 0.45);
      font-size: 0.82rem;
      line-height: 1.2;
      color: #dbeafe;
      max-width: 100%;
    }
    .meta-pill strong {
      color: #f8fafc;
      font-size: 0.75rem;
      text-transform: uppercase;
      letter-spacing: 0.03em;
    }
    .skill-hero-panel {
      min-width: 280px;
      max-width: 360px;
      padding: 0.75rem;
      border-radius: 12px;
      border: 1px solid rgba(255, 255, 255, 0.1);
      background: rgba(2, 6, 23, 0.35);
      display: grid;
      gap: 0.55rem;
    }
    .asset-wrap {
      display: flex;
      flex-wrap: wrap;
      gap: 0.3rem;
      margin-top: 0.2rem;
    }
    .asset {
      font-size: 0.8rem;
      border-radius: 999px;
      padding: 0.15rem 0.55rem;
      border: 1px solid rgba(255, 255, 255, 0.2);
      color: #dbeafe;
    }
    .cmd-wrap { margin-top: 0.1rem; }
    .cmd-wrap ul {
      margin: 0.4rem 0 0;
      padding-left: 1rem;
    }
    .cmd-wrap li { margin: 0.2rem 0; }
    .cmd-wrap code {
      color: #f8fafc;
      background: rgba(148, 163, 184, 0.14);
      border: 1px solid rgba(255, 255, 255, 0.14);
      padding: 0.05rem 0.35rem;
      border-radius: 6px;
      word-break: break-word;
    }
    .cmd-details {
      border: 1px solid rgba(255, 255, 255, 0.12);
      border-radius: 10px;
      padding: 0.5rem 0.6rem;
      background: rgba(15, 23, 42, 0.45);
    }
    .cmd-details summary {
      cursor: pointer;
      font-weight: 700;
      color: #dbeafe;
      font-size: 0.88rem;
      list-style: none;
    }
    .cmd-details summary::-webkit-details-marker {
      display: none;
    }
    .cmd-details summary::after {
      content: ' +';
      color: #93c5fd;
    }
    .cmd-details[open] summary::after {
      content: ' -';
    }
    .cmd-install-wrap {
      margin-top: 0;
      padding: 0.55rem;
      border-radius: 10px;
      border: 1px solid rgba(59, 130, 246, 0.35);
      background: linear-gradient(120deg, rgba(2, 6, 23, 0.75), rgba(15, 23, 42, 0.65));
    }
    .install-command-box {
      margin-top: 0.45rem;
      display: grid;
      grid-template-columns: 1fr auto;
      gap: 0.45rem;
      align-items: start;
    }
    .install-command-box code {
      line-height: 1.5;
      padding: 0.35rem 0.5rem;
    }
    .copy-command-button {
      border: 1px solid rgba(96, 165, 250, 0.55);
      background: rgba(59, 130, 246, 0.18);
      color: #dbeafe;
      border-radius: 8px;
      padding: 0.4rem 0.72rem;
      font-size: 0.83rem;
      font-weight: 700;
      cursor: pointer;
      transition: background 120ms ease, transform 120ms ease;
    }
    .copy-command-button:hover {
      background: rgba(59, 130, 246, 0.28);
      transform: translateY(-1px);
    }
    .copy-command-button.is-copied {
      border-color: rgba(16, 185, 129, 0.65);
      background: rgba(16, 185, 129, 0.22);
      color: #bbf7d0;
    }
    .copy-command-meta {
      margin: 0.45rem 0 0;
      font-size: 0.79rem;
      color: #93c5fd;
    }
    .link-wrap {
      margin-top: 0.4rem;
      display: grid;
      gap: 0.3rem;
    }
    .repo-links {
      display: flex;
      flex-wrap: wrap;
      gap: 0.5rem;
    }
    .repo-links a {
      color: #93c5fd;
      text-decoration: none;
      font-size: 0.88rem;
      border: 1px solid rgba(147, 197, 253, 0.45);
      border-radius: 999px;
      padding: 0.2rem 0.55rem;
    }
    .telemetry-panel {
      margin-top: 0.8rem;
      margin-bottom: 0.75rem;
      padding: 0.8rem;
      border-radius: 12px;
      border: 1px solid rgba(255, 255, 255, 0.1);
      background: rgba(2, 6, 23, 0.34);
      display: grid;
      gap: 0.42rem;
    }
    .skill-doc-head {
      margin-top: 1.1rem;
      display: grid;
      gap: 0.2rem;
    }
    .skill-doc-head h2 {
      margin: 0;
    }
    .skill-doc-head p {
      margin: 0;
      color: #94a3b8;
    }
    .vote-row {
      display: flex;
      gap: 0.45rem;
      flex-wrap: wrap;
    }
    .vote-button {
      padding: 0.45rem 0.8rem;
      border-radius: 999px;
      border: 1px solid rgba(255, 255, 255, 0.16);
      background: rgba(255, 255, 255, 0.03);
      color: #e5e7eb;
      cursor: pointer;
      font-weight: 600;
    }
    .vote-button.is-active {
      background: rgba(16, 185, 129, 0.14);
      border-color: rgba(16, 185, 129, 0.42);
      color: #a7f3d0;
    }
    .vote-button[data-vote="not-helpful"].is-active {
      background: rgba(244, 63, 94, 0.14);
      border-color: rgba(244, 63, 94, 0.42);
      color: #fecdd3;
    }
    .telemetry-meta {
      margin: 0;
      font-size: 0.85rem;
      color: #94a3b8;
    }
    .recommend-section {
      margin-top: 1.25rem;
      padding: 1rem;
      border-radius: 16px;
      border: 1px solid rgba(255, 255, 255, 0.08);
      background: rgba(255, 255, 255, 0.02);
    }
    .recommend-head h2 {
      margin: 0.35rem 0 0.85rem;
    }
    .recommend-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
      gap: 0.75rem;
    }
    .recommend-card {
      padding: 0.9rem;
      border-radius: 12px;
      background: rgba(15, 23, 42, 0.6);
      border: 1px solid rgba(255, 255, 255, 0.08);
    }
    .recommend-card a {
      color: #e5e7eb;
      text-decoration: none;
      font-weight: 700;
    }
    .recommend-card p,
    .recommend-card span {
      margin: 0.3rem 0 0;
      color: #94a3b8;
      font-size: 0.88rem;
    }
    .recommend-empty {
      margin: 0;
      color: #94a3b8;
    }
    @media (max-width: 900px) {
      .skill-hero { flex-direction: column; }
      .skill-hero-panel {
        width: 100%;
        max-width: none;
      }
      .meta-pill {
        width: 100%;
        justify-content: space-between;
      }
      .install-command-box {
        grid-template-columns: 1fr;
      }
      .copy-command-button {
        justify-self: start;
      }
    }
    .skill-content { margin-top: 0.75rem; }
  </style>

  <script>
    import {
      getHelpfulVoteStats,
      getRecommendedSkills,
      getSkillViewStats,
      trackHelpfulVote,
      trackSkillView
    } from '../../lib/client-telemetry';

    const skillProfile = JSON.parse(document.getElementById('skill-profile-json')?.textContent || '{}');
    const recommendationCatalog = JSON.parse(document.getElementById('skill-recommendation-catalog')?.textContent || '[]');
    const voteContainer = document.getElementById('helpful-vote-actions');
    const viewMeta = document.getElementById('skill-view-meta');
    const voteMeta = document.getElementById('skill-vote-meta');
    const recommendationsContainer = document.getElementById('recommended-skills-detail');
    const copyInstallButton = document.getElementById('copy-install-command');
    const copyInstallMeta = document.getElementById('copy-install-command-meta');

    async function copyInstallCommand(command: string) {
      if (!command) return;
      try {
        await navigator.clipboard.writeText(command);
        if (copyInstallButton instanceof HTMLButtonElement) {
          copyInstallButton.classList.add('is-copied');
          copyInstallButton.textContent = 'Copiado';
        }
        if (copyInstallMeta) {
          copyInstallMeta.textContent = 'Comando copiado al portapapeles.';
        }
      } catch {
        if (copyInstallMeta) {
          copyInstallMeta.textContent = 'No se pudo copiar automáticamente. Copia el comando manualmente.';
        }
      } finally {
        setTimeout(() => {
          if (copyInstallButton instanceof HTMLButtonElement) {
            copyInstallButton.classList.remove('is-copied');
            copyInstallButton.textContent = 'Copiar';
          }
          if (copyInstallMeta) {
            copyInstallMeta.textContent = 'Copia el comando y ejecútalo en tu terminal.';
          }
        }, 1800);
      }
    }

    function renderVoteState() {
      const stats = getHelpfulVoteStats(skillProfile.id);
      const buttons = voteContainer?.querySelectorAll('.vote-button') || [];
      buttons.forEach((button) => {
        if (!(button instanceof HTMLButtonElement)) return;
        button.classList.toggle('is-active', button.dataset.vote === stats.userVote);
      });
      if (voteMeta) {
        voteMeta.textContent = `${stats.helpful} útil · ${stats.notHelpful} no útil`;
      }
    }

    const viewEntry = trackSkillView(skillProfile);
    if (viewMeta && viewEntry) {
      viewMeta.textContent = `${viewEntry.count} vistas locales · última visita ${new Date(viewEntry.lastViewedAt).toLocaleDateString('es-ES')}`;
    } else if (viewMeta) {
      const currentViewStats = getSkillViewStats(skillProfile.id);
      if (currentViewStats) {
        viewMeta.textContent = `${currentViewStats.count} vistas locales · última visita ${new Date(currentViewStats.lastViewedAt).toLocaleDateString('es-ES')}`;
      }
    }

    renderVoteState();
    voteContainer?.addEventListener('click', (event) => {
      const target = event.target;
      if (!(target instanceof HTMLButtonElement)) return;
      const vote = target.dataset.vote;
      if (vote !== 'helpful' && vote !== 'not-helpful') return;
      trackHelpfulVote(skillProfile.id, vote);
      renderVoteState();
    });

    copyInstallButton?.addEventListener('click', () => {
      const command = copyInstallButton instanceof HTMLButtonElement
        ? copyInstallButton.dataset.command || ''
        : '';
      copyInstallCommand(command);
    });

    const recommended = getRecommendedSkills(recommendationCatalog, skillProfile.id, 4);
    if (recommendationsContainer && recommended.length > 0) {
      recommendationsContainer.innerHTML = recommended.map((entry) => `
        <article class="recommend-card">
          <a href="${entry.url}">${entry.title}</a>
          <p>${entry.description || 'Skill relacionada.'}</p>
          <span>${entry.repoName || 'Skill'} · ${((entry.score || 0) * 100).toFixed(1)}%</span>
        </article>
      `).join('');
    }
  </script>
  <script id="skill-profile-json" type="application/json" set:html={JSON.stringify({
    id: skill.id,
    title: skill.title,
    url: skill.url,
    description: skill.description,
    repoName: skill.repoName,
    frameworks: skill.frameworks,
    testTypes: skill.testTypes,
    tags: skill.tags,
    score: skill.score
  })}></script>
  <script id="skill-recommendation-catalog" type="application/json" set:html={JSON.stringify(recommendationCatalog)}></script>
</Layout>
