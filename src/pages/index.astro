---
import Layout from "../layouts/Layout.astro";
import type { RepoConfig } from "../lib/config";
import { readReposConfig } from "../lib/config";
import { requireToken } from "../lib/github.service";
import { fetchReadme } from "../lib/repo.service";
import { collectAllSkills } from "../lib/skill.service";
import { mdToHtml } from "../lib/markdown";

// Carga el README base para usarlo como homepage del portal.
requireToken();

// Config simple del repo fuente; reutiliza fetchReadme para evitar URLs hardcodeadas.
const homeRepo: RepoConfig = {
  id: "private-skills-cli",
  name: "Private Skills CLI",
  repoUrl: "git@github.com:aI-dev-innovators/private-skills-cli.git",
  defaultBranch: "main",
  readmePath: "README.md",
};

// Renderiza README remoto a HTML para inyectarlo en server.
const readme = (await fetchReadme(homeRepo)) || "# README no disponible";
const homeHtml = mdToHtml(readme);
const repos = readReposConfig();
const skills = await collectAllSkills(repos);
const telemetryCatalog = skills.map((skill) => ({
  id: skill.id,
  title: skill.title,
  url: skill.url,
  description: skill.description,
  repoName: skill.repoName,
  frameworks: skill.frameworks,
  testTypes: skill.testTypes,
  tags: skill.tags,
  score: skill.score
}));
---

<Layout title="Skills Portal" description="Documentación interna de skills">
  <section class="hero">
    <div>
      <p class="eyebrow">Portal interno</p>
      <h1>Skills y repos en un solo lugar</h1>
      <p class="lede">
        Fetch en vivo desde GitHub (READMEs y SKILL.md) con tu token, caché en memoria y filtros rápidos.
      </p>
      <div class="cta-row">
        <a class="primary" href="/skills">Ver skills</a>
        <a class="ghost" href="/repos">Ver repos</a>
      </div>
    </div>
    <div class="hero-panel">
      <p class="panel-title">Acceso directo</p>
      <div class="links">
        <a class="link-card" href="/skills">
          <span class="pill">Skills</span>
          <h3>Catálogo en vivo</h3>
          <p>SKILL.md desde GitHub con caché</p>
        </a>
        <a class="link-card" href="/repos">
          <span class="pill">Repos</span>
          <h3>README online</h3>
          <p>Documentación por repo registrada</p>
        </a>
      </div>
    </div>
  </section>

  <section class="readme-section">
    <div class="readme-head">
      <div>
        <p class="eyebrow">Inicio</p>
        <h2>Guía principal</h2>
        <p class="lede">Contenido proveniente del README de private-skills-cli para contextualizar el portal.</p>
      </div>
    </div>
    <div class="repo-content readme-card" set:html={homeHtml}></div>
  </section>

  <section class="personalization-section">
    <div class="personalization-grid">
      <article class="personal-card">
        <p class="eyebrow">Tu actividad</p>
        <h2>Recientes</h2>
        <div id="recent-skill-activity" class="personal-list">
          <p class="empty-state">Aún no hay vistas registradas.</p>
        </div>
      </article>
      <article class="personal-card">
        <p class="eyebrow">Tus búsquedas</p>
        <h2>Términos recientes</h2>
        <div id="recent-search-activity" class="personal-list">
          <p class="empty-state">Todavía no se registran búsquedas.</p>
        </div>
      </article>
      <article class="personal-card personal-card-wide">
        <p class="eyebrow">Para ti</p>
        <h2>Recomendadas por navegación</h2>
        <div id="recommended-skills-home" class="recommend-grid">
          <p class="empty-state">Explora algunas skills para ver recomendaciones personalizadas.</p>
        </div>
      </article>
    </div>
  </section>

  <style>
    .hero {
      display: grid;
      grid-template-columns: 1.2fr 1fr;
      gap: 1.5rem;
      padding: 2rem;
      border: 1px solid rgba(255, 255, 255, 0.08);
      border-radius: 18px;
      background:
        radial-gradient(
          circle at 20% 20%,
          rgba(56, 189, 248, 0.12),
          transparent 35%
        ),
        radial-gradient(
          circle at 80% 0%,
          rgba(168, 85, 247, 0.16),
          transparent 32%
        ),
        #0c101a;
      box-shadow: 0 20px 60px rgba(0, 0, 0, 0.45);
    }
    .eyebrow {
      text-transform: uppercase;
      letter-spacing: 0.14em;
      font-size: 0.8rem;
      color: #a5b4fc;
      margin: 0 0 0.5rem;
    }
    h1 {
      margin: 0;
      font-size: clamp(1.9rem, 3vw, 2.5rem);
      letter-spacing: -0.02em;
    }
    .lede {
      color: #cbd5e1;
      margin: 0.8rem 0 1.4rem;
      line-height: 1.5;
    }
    .cta-row {
      display: flex;
      gap: 0.75rem;
      flex-wrap: wrap;
    }
    .primary,
    .ghost {
      padding: 0.9rem 1.1rem;
      border-radius: 12px;
      text-decoration: none;
      font-weight: 700;
      border: 1px solid rgba(255, 255, 255, 0.16);
    }
    .primary {
      background: #2563eb;
      color: #e5e7eb;
      border-color: #2563eb;
    }
    .primary:hover {
      background: #1d4ed8;
    }
    .ghost {
      color: #c7d2fe;
    }
    .ghost:hover {
      color: #e0e7ff;
      border-color: rgba(255, 255, 255, 0.3);
    }

    .hero-panel {
      background: rgba(255, 255, 255, 0.03);
      border: 1px solid rgba(255, 255, 255, 0.08);
      border-radius: 14px;
      padding: 1rem;
      backdrop-filter: blur(6px);
    }
    .panel-title {
      margin: 0 0 0.75rem;
      color: #cbd5e1;
      font-weight: 700;
    }
    .links {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
      gap: 0.75rem;
    }
    .link-card {
      display: block;
      padding: 0.9rem;
      border: 1px solid rgba(255, 255, 255, 0.08);
      border-radius: 12px;
      background: rgba(15, 23, 42, 0.6);
      text-decoration: none;
      color: #e5e7eb;
    }
    .link-card h3 {
      margin: 0.35rem 0 0.2rem;
    }
    .link-card p {
      margin: 0;
      color: #cbd5e1;
    }
    .pill {
      display: inline-flex;
      align-items: center;
      padding: 0.15rem 0.55rem;
      border-radius: 999px;
      background: rgba(148, 163, 184, 0.18);
      color: #cbd5e1;
      font-size: 0.85rem;
      border: 1px solid rgba(255, 255, 255, 0.12);
      margin: 0;
    }

    .readme-section { margin-top: 2rem; display: flex; flex-direction: column; gap: 1rem; }
    .readme-head h2 { margin: 0.35rem 0 0.3rem; }
    .readme-card { margin: 0; }
    .personalization-section {
      margin-top: 2rem;
    }
    .personalization-grid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 1rem;
    }
    .personal-card {
      padding: 1rem;
      border-radius: 16px;
      border: 1px solid rgba(255, 255, 255, 0.08);
      background: rgba(255, 255, 255, 0.02);
      box-shadow: 0 16px 40px rgba(0, 0, 0, 0.22);
    }
    .personal-card-wide {
      grid-column: 1 / -1;
    }
    .personal-card h2 {
      margin: 0.1rem 0 0.9rem;
    }
    .personal-list,
    .recommend-grid {
      display: grid;
      gap: 0.6rem;
    }
    .activity-item,
    .recommend-item {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 0.8rem;
      padding: 0.8rem 0.9rem;
      border-radius: 12px;
      background: rgba(15, 23, 42, 0.58);
      border: 1px solid rgba(255, 255, 255, 0.06);
    }
    .activity-item a,
    .recommend-item a {
      color: #e5e7eb;
      text-decoration: none;
      font-weight: 600;
    }
    .activity-item span,
    .recommend-item span {
      color: #94a3b8;
      font-size: 0.86rem;
    }
    .empty-state {
      margin: 0;
      color: #94a3b8;
    }

    @media (max-width: 900px) {
      .hero {
        grid-template-columns: 1fr;
      }
      .personalization-grid {
        grid-template-columns: 1fr;
      }
    }
  </style>

  <script>
    import { getRecommendedSkills, getRecentSearches, getTopViewedSkills } from '../lib/client-telemetry';

    const homeCatalog = JSON.parse(document.getElementById('telemetry-catalog-home')?.textContent || '[]');
    const recentSkillContainer = document.getElementById('recent-skill-activity');
    const recentSearchContainer = document.getElementById('recent-search-activity');
    const recommendedContainer = document.getElementById('recommended-skills-home');

    const topViewed = getTopViewedSkills(4);
    if (recentSkillContainer && topViewed.length > 0) {
      recentSkillContainer.innerHTML = topViewed.map((entry) => `
        <div class="activity-item">
          <div>
            <a href="${entry.profile.url}">${entry.profile.title}</a>
            <span>${entry.profile.repoName || 'Skill'} · ${entry.count} vistas</span>
          </div>
          <span>${new Date(entry.lastViewedAt).toLocaleDateString('es-ES')}</span>
        </div>
      `).join('');
    }

    const recentSearches = getRecentSearches(5);
    if (recentSearchContainer && recentSearches.length > 0) {
      recentSearchContainer.innerHTML = recentSearches.map((entry) => `
        <div class="activity-item">
          <div>
            <strong>${entry.term}</strong>
            <span>${entry.count} búsquedas</span>
          </div>
          <span>${new Date(entry.lastSearchedAt).toLocaleDateString('es-ES')}</span>
        </div>
      `).join('');
    }

    const recommended = getRecommendedSkills(homeCatalog, undefined, 4);
    if (recommendedContainer && recommended.length > 0) {
      recommendedContainer.innerHTML = recommended.map((skill) => `
        <div class="recommend-item">
          <div>
            <a href="${skill.url}">${skill.title}</a>
            <span>${skill.repoName || 'Skill'} · ${(skill.frameworks || []).join(', ') || 'general'}</span>
          </div>
          <span>${((skill.score || 0) * 100).toFixed(1)}%</span>
        </div>
      `).join('');
    }
  </script>
  <script id="telemetry-catalog-home" type="application/json" set:html={JSON.stringify(telemetryCatalog)}></script>
</Layout>
