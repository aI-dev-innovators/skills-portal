---
import Layout from '../../layouts/Layout.astro';
import { readReposConfig } from '../../lib/config';
import { collectAllSkills } from '../../lib/skill.service';
import { fetchRepoMetrics } from '../../lib/repo.service';

const repos = (await readReposConfig()).sort((a, b) => a.name.localeCompare(b.name));
const totalRepos = repos.length;
const skills = await collectAllSkills(repos);
const skillsPerRepo = skills.reduce<Record<string, number>>((acc, skill) => {
  const key = skill.repoId || skill.repoName || '';
  acc[key] = (acc[key] || 0) + 1;
  return acc;
}, {});
const tagOptions = Array.from(new Set(repos.flatMap((r) => r.tags || []))).sort();
const repoRows = await Promise.all(
  repos.map(async (repo) => {
    const metrics = await fetchRepoMetrics(repo);
    return { repo, metrics };
  })
);

function formatShortDate(value: string | null): string {
  if (!value) return 'Sin datos';
  const parsed = new Date(value);
  if (Number.isNaN(parsed.getTime())) return 'Sin datos';
  return parsed.toLocaleDateString('es-ES', {
    year: 'numeric',
    month: 'short',
    day: '2-digit'
  });
}
---
<Layout title="Repos" description="Repositorios registrados">
  <section class="hero">
    <div>
      <p class="eyebrow">Catálogo de repos</p>
      <h1>Repos con skills y documentación</h1>
      <p class="lede">Consulta README y SKILL.md directamente desde GitHub sin clonar. Usa el buscador para filtrar rápido.</p>
      <div class="stats">
        <div class="stat">
          <span class="stat-label">Repos registrados</span>
          <span class="stat-value">{totalRepos}</span>
        </div>
        <div class="stat">
          <span class="stat-label">Fetch en vivo</span>
          <span class="stat-value">GitHub API</span>
        </div>
      </div>
    </div>
    <div class="hero-card" id="repo-card">
      <p class="hero-label">Búsqueda</p>
      <div class="search-box">
        <input type="search" placeholder="Buscar por nombre, descripción o tag" oninput="filterRepos()" />
      </div>
      <div class="filter-row">
        <select id="repo-tag" onchange="filterRepos()">
          <option value="">Tag (todos)</option>
          {tagOptions.map((t) => (
            <option value={t}>{t}</option>
          ))}
        </select>
        <select id="repo-status" onchange="filterRepos()">
          <option value="">Estado (todos)</option>
          <option value="with">Con skills</option>
          <option value="without">Solo README</option>
        </select>
      </div>
      <p class="hint">Filtra por texto, tag y estado (con skills / solo README).</p>
      <p class="hint" id="repo-results-count" aria-live="polite">{totalRepos} repos visibles</p>
    </div>
  </section>

  <section class="repo-section">
    <div class="repo-header">
      <p class="eyebrow">Listado</p>
      <h2>Repositorios</h2>
    </div>
    <div class="repo-list" id="repo-list">
      {repoRows.map(({ repo, metrics }) => {
        const tagString = (repo.tags || []).join(' ').toLowerCase();
        const hasSkills = (skillsPerRepo[repo.id] || skillsPerRepo[repo.name] || 0) > 0;
        const status = hasSkills ? 'with' : 'without';
        return (
          <article
            class="repo-row"
            data-search={`${repo.name} ${repo.description || ''} ${tagString}`.toLowerCase()}
            data-tags={tagString}
            data-status={status}
          >
            <div class="row-main">
              <div>
                <p class="repo-id">{repo.id}</p>
                <h3><a href={`/repos/${repo.id}/`}>{repo.name}</a></h3>
                {repo.description && <p class="repo-desc">{repo.description}</p>}
                <div class="tag-row">
                  {(repo.tags || []).map((tag) => (
                    <span class="tag">{tag}</span>
                  ))}
                  <span class="tag" style="opacity:0.8">{hasSkills ? 'Con skills' : 'Solo README'}</span>
                </div>
                <div class="metrics-row">
                  <span class="metric">★ {metrics.stars}</span>
                  <span class="metric">⑂ {metrics.forks}</span>
                  <span class="metric">👥 {metrics.contributors}</span>
                  <span class="metric">Último commit: {formatShortDate(metrics.lastCommitDate)}</span>
                </div>
              </div>
            </div>
            <div class="row-cta">
              <a class="ghost" href={`/repos/${repo.id}/`}>Ver detalles →</a>
            </div>
          </article>
        );
      })}
    </div>
    <p class="repo-empty" id="repo-empty-state" hidden>No hay repositorios que coincidan con tu filtro.</p>
  </section>

  <style>
    .hero {
      background: radial-gradient(circle at 20% 20%, rgba(61, 217, 196, 0.18), transparent 35%),
        radial-gradient(circle at 80% 0%, rgba(255, 180, 84, 0.14), transparent 32%),
        var(--panel);
      border: 1px solid var(--border);
      border-radius: 18px;
      padding: 2rem;
      display: grid;
      grid-template-columns: 2fr 1fr;
      gap: 1.5rem;
      box-shadow: var(--shadow-soft);
      margin: 0 0 1rem;
    }
    .eyebrow {
      text-transform: uppercase;
      letter-spacing: 0.12em;
      font-size: 0.8rem;
      color: var(--login-eyebrow);
      margin: 0 0 0.4rem;
    }
    h1 {
      margin: 0;
      font-size: clamp(1.8rem, 3vw, 2.4rem);
      letter-spacing: -0.02em;
    }
    .lede {
      color: var(--muted);
      margin: 0.6rem 0 1.2rem;
      max-width: 720px;
      line-height: 1.5;
    }
    .stats {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
      gap: 1rem;
    }
    .stat {
      background: color-mix(in srgb, var(--panel-elevated) 75%, transparent);
      border: 1px solid var(--border);
      border-radius: 12px;
      padding: 0.9rem 1rem;
    }
    .stat-label { color: var(--muted); font-size: 0.9rem; display: block; }
    .stat-value { font-weight: 700; font-size: 1.2rem; }
    .hero-card {
      background: color-mix(in srgb, var(--panel-elevated) 74%, transparent);
      border: 1px solid var(--border);
      border-radius: 12px;
      padding: 1rem;
      backdrop-filter: blur(6px);
      align-self: center;
    }
    .hero-label { color: var(--muted); margin: 0 0 0.4rem; font-weight: 600; }
    .search-box input {
      width: 100%;
      padding: 0.9rem 1rem;
      border-radius: 12px;
      border: 1px solid var(--border);
      background: var(--input-bg);
      color: var(--text);
      font-size: 1rem;
    }
    .search-box input::placeholder { color: var(--placeholder); }
    .hint { color: var(--muted); margin: 0.5rem 0 0; font-size: 0.9rem; }
    .filter-row { display: flex; gap: 0.75rem; margin-top: 0.75rem; flex-wrap: wrap; }
    .filter-row select {
      padding: 0.65rem 0.75rem;
      border-radius: 10px;
      border: 1px solid var(--border);
      background: var(--input-bg);
      color: var(--text);
    }

    .repo-section { 
      margin-top: 3rem;
    }
    .repo-header {
      margin-bottom: 1.5rem;
    }
    .repo-header .eyebrow {
      text-transform: uppercase;
      letter-spacing: 0.12em;
      font-size: 0.8rem;
      color: var(--login-eyebrow);
      margin: 0 0 0.4rem;
    }
    .repo-header h2 { 
      margin: 0.2rem 0 0.8rem;
      font-size: clamp(1.6rem, 2.5vw, 2rem);
      letter-spacing: -0.02em;
    }
    .repo-list {
      display: flex;
      flex-direction: column;
      gap: 0.75rem;
    }
    .repo-empty {
      margin: 0.9rem 0 0;
      padding: 0.8rem 0.95rem;
      border-radius: 10px;
      border: 1px dashed var(--border-strong);
      background: color-mix(in srgb, var(--panel) 82%, transparent);
      color: var(--muted);
      font-size: 0.9rem;
    }
    .repo-row {
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      gap: 1rem;
      padding: 1rem 1.25rem;
      background: color-mix(in srgb, var(--panel-elevated) 75%, transparent);
      border: 1px solid var(--border);
      border-radius: 12px;
      transition: background 0.2s, border-color 0.2s;
    }
    .repo-row:hover {
      background: color-mix(in srgb, var(--panel-elevated) 86%, transparent);
      border-color: var(--border-strong);
    }
    .row-main {
      flex: 1;
      min-width: 0;
    }
    .row-main h3 { 
      margin: 0.1rem 0 0.35rem;
      font-size: 1.05rem;
    }
    .repo-id { 
      color: var(--muted); 
      margin: 0 0 0.3rem; 
      font-size: 0.85rem;
      letter-spacing: 0.05em;
      text-transform: lowercase;
    }
    .repo-desc { 
      margin: 0.4rem 0 0.7rem; 
      color: var(--muted);
      font-size: 0.9rem;
      line-height: 1.4;
    }
    .tag-row { 
      display: flex; 
      gap: 0.35rem; 
      flex-wrap: wrap;
      margin-bottom: 0.6rem;
    }
    .tag {
      padding: 0.2rem 0.7rem;
      border-radius: 999px;
      border: 1px solid var(--border);
      color: var(--text);
      font-size: 0.82rem;
      background: color-mix(in srgb, var(--panel-elevated) 80%, transparent);
      white-space: nowrap;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      height: 30px;
      line-height: 1;
    }
    .metrics-row {
      margin-top: 0.6rem;
      display: flex;
      gap: 0.35rem;
      flex-wrap: wrap;
      align-items: center;
    }
    .metric {
      padding: 0.2rem 0.7rem;
      border-radius: 999px;
      border: 1px solid color-mix(in srgb, var(--accent) 55%, transparent);
      background: color-mix(in srgb, var(--accent) 16%, transparent);
      color: var(--text);
      font-size: 0.82rem;
      white-space: nowrap;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      height: 30px;
      line-height: 1;
    }
    .row-cta { 
      align-self: center;
      flex-shrink: 0;
      padding-left: 1rem;
    }
    .ghost {
      color: var(--action-text);
      text-decoration: none;
      font-weight: 600;
      font-size: 0.95rem;
      padding: 0.5rem 1rem;
      border-radius: 8px;
      display: inline-flex;
      align-items: center;
      transition: all 0.2s;
      border: 1px solid var(--border-strong);
      background: var(--action-bg);
    }
    .ghost:hover { 
      color: var(--nav-active-text);
      background: var(--action-bg-hover);
      border-color: color-mix(in srgb, var(--accent) 60%, transparent);
    }
    a { color: var(--accent); }
    a:hover { color: var(--link-hover); }

    @media (max-width: 800px) {
      .hero { 
        grid-template-columns: 1fr;
        padding: 1.5rem;
      }
      .row-cta { 
        width: 100%; 
        text-align: right;
        padding-left: 0;
        padding-top: 0.5rem;
      }
      .repo-row { 
        flex-direction: column;
        padding: 1rem 1.25rem;
      }
      .repo-desc {
        margin: 0.3rem 0 0.6rem;
      }
    }
  </style>

  <script>
    const list = document.getElementById('repo-list');
    const tagSelect = document.getElementById('repo-tag');
    const statusSelect = document.getElementById('repo-status');
    const resultsCount = document.getElementById('repo-results-count');
    const emptyState = document.getElementById('repo-empty-state');

    function filterRepos() {
      if (!list) return;
      const term = (document.querySelector('#repo-card input') as HTMLInputElement | null)?.value?.toLowerCase().trim() || '';
      const tag = (tagSelect as HTMLSelectElement | null)?.value.toLowerCase() || '';
      const status = (statusSelect as HTMLSelectElement | null)?.value.toLowerCase() || '';
      const rows = Array.from(list.children) as HTMLElement[];
      let visibleCount = 0;
      rows.forEach((row) => {
        const haystack = (row.dataset.search || '').toLowerCase();
        const tags = (row.dataset.tags || '').toLowerCase();
        const rowStatus = (row.dataset.status || '').toLowerCase();
        const matchesText = !term || haystack.includes(term);
        const matchesTag = !tag || tags.split(' ').includes(tag);
        const matchesStatus = !status || rowStatus === status;
        const visible = matchesText && matchesTag && matchesStatus;
        row.style.display = visible ? 'flex' : 'none';
        if (visible) visibleCount += 1;
      });

      if (resultsCount) {
        resultsCount.textContent = `${visibleCount} repos visibles`;
      }
      if (emptyState) {
        if (visibleCount === 0) {
          emptyState.removeAttribute('hidden');
        } else {
          emptyState.setAttribute('hidden', 'hidden');
        }
      }
    }

    filterRepos();

    // Exponer función para el oninput inline.
    // @ts-ignore
    window.filterRepos = filterRepos;
  </script>
</Layout>
