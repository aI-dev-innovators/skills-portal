---
import Layout from '../../layouts/Layout.astro';
import { readReposConfig } from '../../lib/config';
import { requireToken } from '../../lib/github.service';
import { fetchReadme, fetchRepoMetrics, parseRepoSlug } from '../../lib/repo.service';
import { mdToHtml } from '../../lib/markdown';

export async function getStaticPaths() {
  requireToken();
  const repos = await readReposConfig();
  return repos.map((repo) => ({ params: { id: repo.id } }));
}

const { id } = Astro.params;
if (!id) throw new Error('Repo ID requerido');

requireToken();
const repos = await readReposConfig();
const repo = repos.find((r) => r.id === id);

if (!repo) {
  return Astro.redirect('/repos');
}

const readme = (await fetchReadme(repo)) || '# README no encontrado';
const html = mdToHtml(readme);
const metrics = await fetchRepoMetrics(repo);
const repoSlug = parseRepoSlug(repo.repoUrl || '');
// Normaliza la URL del repo a vista web para el CTA.
const repoWebUrl = (() => {
  if (repoSlug) return `https://github.com/${repoSlug.owner}/${repoSlug.name}`;
  return repo.repoUrl;
})();
const repoFullName = repoSlug ? `${repoSlug.owner}/${repoSlug.name}` : repo.name;

const formattedCommitDate = (() => {
  if (!metrics.lastCommitDate) return 'Sin datos';
  const parsed = new Date(metrics.lastCommitDate);
  if (Number.isNaN(parsed.getTime())) return 'Sin datos';
  return parsed.toLocaleDateString('es-ES', {
    year: 'numeric',
    month: 'short',
    day: '2-digit'
  });
})();
---
<Layout title={repo.name} description={repo.description || 'Repositorio registrado'}>
  <div class="page-title">
    <div>
      <h1>{repo.name}</h1>
      {repo.description && <p>{repo.description}</p>}
      <div>
        {(repo.tags || []).map((tag) => (
          <span class="badge">{tag}</span>
        ))}
      </div>
      <div class="metrics-row">
        <span class="metric">★ {metrics.stars} stars</span>
        <span class="metric">⑂ {metrics.forks} forks</span>
        <span class="metric">👥 {metrics.contributors} contributors</span>
        <span class="metric">Último commit: {formattedCommitDate}</span>
      </div>
    </div>
    {repoWebUrl && <a class="external" href={repoWebUrl} rel="noreferrer" target="_blank">Ver en GitHub</a>}
  </div>
  <div class="repo-content" set:html={html}></div>

  <style>
    .page-title {
      display: flex;
      align-items: flex-start;
      justify-content: space-between;
      gap: 1rem;
      padding: 1.5rem;
      border: 1px solid var(--border);
      border-radius: 16px;
      background: radial-gradient(circle at 15% 20%, rgba(61, 217, 196, 0.18), transparent 40%),
        radial-gradient(circle at 85% 0%, rgba(255, 180, 84, 0.14), transparent 38%),
        var(--panel);
      box-shadow: var(--shadow-soft);
      margin-bottom: 1rem;
    }
    .page-title h1 { margin: 0.3rem 0 0.4rem; letter-spacing: -0.01em; }
    .page-title p { margin: 0; color: var(--muted); }
    .page-title .badge {
      margin: 0 0.4rem 0.3rem 0;
      background: rgba(148, 163, 184, 0.12);
      border: 1px solid rgba(255, 255, 255, 0.12);
      color: var(--text);
    }
    .metrics-row {
      margin-top: 0.65rem;
      display: flex;
      gap: 0.4rem;
      flex-wrap: wrap;
    }
    .metric {
      padding: 0.2rem 0.6rem;
      border-radius: 999px;
      border: 1px solid rgba(61, 217, 196, 0.35);
      background: rgba(61, 217, 196, 0.12);
      color: #d2fff9;
      font-size: 0.82rem;
      display: inline-flex;
      align-items: center;
      line-height: 1;
      white-space: nowrap;
    }
    .external {
      align-self: center;
      color: var(--accent);
      text-decoration: none;
      font-weight: 700;
    }
    .external:hover { color: var(--accent-strong); }
    .repo-content { margin-top: 1.25rem; }
  </style>

  <script>
    import { startTelemetrySession } from '../../lib/client-telemetry';

    const repoProfile = JSON.parse(document.getElementById('repo-profile-json')?.textContent || '{}');
    startTelemetrySession({
      type: 'repository_view',
      payload: {
        repositoryId: repoProfile.id || 'unknown-repository',
        repositoryName: repoProfile.name,
        fullName: repoProfile.fullName,
        githubUrl: repoProfile.githubUrl,
        description: repoProfile.description,
        sourcePage: '/repos'
      },
      intervalMs: 30_000,
      initialDelayMs: 10_000
    });
  </script>
  <script is:inline id="repo-profile-json" type="application/json" set:html={JSON.stringify({
    id: repo.id,
    name: repo.name,
    fullName: repoFullName,
    githubUrl: repoWebUrl,
    description: repo.description || ''
  })}></script>
</Layout>
