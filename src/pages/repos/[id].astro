---
import Layout from '../../layouts/Layout.astro';
import { readReposConfig } from '../../lib/config';
import { requireToken } from '../../lib/github.service';
import { fetchReadme, fetchRepoMetrics, parseRepoSlug } from '../../lib/repo.service';
import { mdToHtml } from '../../lib/markdown';

export async function getStaticPaths() {
  requireToken();
  const repos = await readReposConfig();
  return repos.map((repo) => ({ params: { id: repo.id } }));
}

const { id } = Astro.params;
if (!id) throw new Error('Repo ID requerido');

requireToken();
const repos = await readReposConfig();
const repo = repos.find((r) => r.id === id);

if (!repo) {
  return Astro.redirect('/repos');
}

const readme = (await fetchReadme(repo)) || '# README no encontrado';
const html = mdToHtml(readme);
const metrics = await fetchRepoMetrics(repo);
const repoSlug = parseRepoSlug(repo.repoUrl || '');
// Normaliza la URL del repo a vista web para el CTA.
const repoWebUrl = (() => {
  if (repoSlug) return `https://github.com/${repoSlug.owner}/${repoSlug.name}`;
  return repo.repoUrl;
})();
const repoFullName = repoSlug ? `${repoSlug.owner}/${repoSlug.name}` : repo.name;
const addRepoCommand = repo.repoUrl ? `private-skills add ${repo.repoUrl} --name ${repo.id}` : null;

const formattedCommitDate = (() => {
  if (!metrics.lastCommitDate) return 'Sin datos';
  const parsed = new Date(metrics.lastCommitDate);
  if (Number.isNaN(parsed.getTime())) return 'Sin datos';
  return parsed.toLocaleDateString('es-ES', {
    year: 'numeric',
    month: 'short',
    day: '2-digit'
  });
})();
---
<Layout title={repo.name} description={repo.description || 'Repositorio registrado'}>
  <div class="page-title">
    <div class="page-title-main">
      <div>
        <p class="eyebrow">Detalle del repositorio</p>
        <h1>{repo.name}</h1>
        {repo.description && <p class="description">{repo.description}</p>}
      </div>
      <div>
        {(repo.tags || []).map((tag) => (
          <span class="badge">{tag}</span>
        ))}
      </div>
      <div class="metrics-row">
        <span class="metric">★ {metrics.stars} stars</span>
        <span class="metric">⑂ {metrics.forks} forks</span>
        <span class="metric">👥 {metrics.contributors} contributors</span>
        <span class="metric">Último commit: {formattedCommitDate}</span>
      </div>
    </div>
    <aside class="page-title-side">
      {addRepoCommand && (
        <div class="command-card">
          <div>
            <p class="command-title">Agregar este repositorio</p>
            <p class="command-note">Copia el comando y reemplaza la URL si quieres registrar otro origen.</p>
          </div>
          <div class="command-box">
            <code id="repo-add-command">{addRepoCommand}</code>
            <button type="button" class="copy-command-button" id="copy-repo-command" data-command={addRepoCommand}>Copiar</button>
          </div>
        </div>
      )}
      {repoWebUrl && (
        <a class="external-button" href={repoWebUrl} rel="noreferrer" target="_blank">
          Ver repositorio
        </a>
      )}
    </aside>
  </div>
  <div class="repo-content" set:html={html}></div>

  <style>
    .page-title {
      display: grid;
      grid-template-columns: minmax(0, 1fr) 320px;
      gap: 1rem;
      padding: 1.5rem;
      border: 1px solid var(--border);
      border-radius: 16px;
      background: radial-gradient(circle at 15% 20%, rgba(61, 217, 196, 0.18), transparent 40%),
        radial-gradient(circle at 85% 0%, rgba(255, 180, 84, 0.14), transparent 38%),
        var(--panel);
      box-shadow: var(--shadow-soft);
      margin-bottom: 1rem;
    }
    .page-title-main {
      min-width: 0;
      display: grid;
      gap: 0.55rem;
      align-content: start;
    }
    .eyebrow {
      margin: 0;
      text-transform: uppercase;
      letter-spacing: 0.12em;
      font-size: 0.8rem;
      color: var(--login-eyebrow);
    }
    .page-title h1 { margin: 0; letter-spacing: -0.02em; }
    .description { margin: 0; color: var(--muted); line-height: 1.55; max-width: 72ch; }
    .page-title .badge {
      margin: 0 0.4rem 0.3rem 0;
      background: rgba(148, 163, 184, 0.12);
      border: 1px solid rgba(255, 255, 255, 0.12);
      color: var(--text);
    }
    .metrics-row {
      margin-top: 0.65rem;
      display: flex;
      gap: 0.4rem;
      flex-wrap: wrap;
    }
    .metric {
      padding: 0.2rem 0.6rem;
      border-radius: 999px;
      border: 1px solid rgba(61, 217, 196, 0.35);
      background: rgba(61, 217, 196, 0.12);
      color: #d2fff9;
      font-size: 0.82rem;
      display: inline-flex;
      align-items: center;
      line-height: 1;
      white-space: nowrap;
    }
    .page-title-side {
      display: grid;
      gap: 0.65rem;
      align-content: start;
    }
    .command-card {
      padding: 0.95rem;
      border-radius: 14px;
      border: 1px solid var(--border);
      background: color-mix(in srgb, var(--panel-elevated) 82%, transparent);
      display: grid;
      gap: 0.65rem;
    }
    .command-title {
      margin: 0;
      font-weight: 700;
      color: var(--text);
    }
    .command-note {
      margin: 0.2rem 0 0;
      color: var(--muted);
      font-size: 0.86rem;
      line-height: 1.45;
    }
    .command-box {
      display: grid;
      grid-template-columns: minmax(0, 1fr) auto;
      gap: 0.5rem;
      align-items: start;
    }
    .command-box code {
      min-width: 0;
      padding: 0.7rem 0.75rem;
      border-radius: 10px;
      border: 1px solid var(--border);
      background: var(--code-bg);
      color: var(--code-text);
      line-height: 1.45;
      word-break: break-word;
      white-space: pre-wrap;
    }
    .copy-command-button {
      border: 1px solid var(--border-strong);
      background: var(--action-bg);
      color: var(--action-text);
      border-radius: 10px;
      padding: 0.5rem 0.8rem;
      font-weight: 700;
      cursor: pointer;
      transition: background 120ms ease, transform 120ms ease;
    }
    .copy-command-button:hover {
      background: var(--action-bg-hover);
      transform: translateY(-1px);
    }
    .copy-command-button.is-copied {
      border-color: color-mix(in srgb, var(--success) 65%, transparent);
      background: color-mix(in srgb, var(--success) 16%, transparent);
      color: var(--text);
    }
    .external-button {
      align-self: start;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: fit-content;
      color: var(--text);
      text-decoration: none;
      font-weight: 700;
      border: 1px solid var(--border-strong);
      background: color-mix(in srgb, var(--accent) 12%, var(--action-bg));
      border-radius: 999px;
      padding: 0.45rem 0.75rem;
      transition: background 120ms ease, transform 120ms ease, border-color 120ms ease;
    }
    .external-button:hover {
      background: var(--action-bg-hover);
      border-color: rgba(61, 217, 196, 0.55);
      transform: translateY(-1px);
    }
    .repo-content { margin-top: 1.25rem; }
    @media (max-width: 960px) {
      .page-title { grid-template-columns: 1fr; }
    }
    @media (max-width: 560px) {
      .command-box { grid-template-columns: 1fr; }
    }
  </style>

  <script>
    import { startTelemetrySession } from '../../lib/client-telemetry';

    const repoProfile = JSON.parse(document.getElementById('repo-profile-json')?.textContent || '{}');
    const copyRepoCommandButton = document.getElementById('copy-repo-command');
    startTelemetrySession({
      type: 'repository_view',
      payload: {
        repositoryId: repoProfile.id || 'unknown-repository',
        repositoryName: repoProfile.name,
        fullName: repoProfile.fullName,
        githubUrl: repoProfile.githubUrl,
        description: repoProfile.description,
        sourcePage: '/repos'
      },
      intervalMs: 30_000,
      initialDelayMs: 10_000
    });

    copyRepoCommandButton?.addEventListener('click', async () => {
      const command = copyRepoCommandButton instanceof HTMLButtonElement ? copyRepoCommandButton.dataset.command || '' : '';
      if (!command) return;

      try {
        await navigator.clipboard.writeText(command);
        if (copyRepoCommandButton instanceof HTMLButtonElement) {
          copyRepoCommandButton.classList.add('is-copied');
          copyRepoCommandButton.textContent = 'Copiado';
        }
        window.setTimeout(() => {
          if (copyRepoCommandButton instanceof HTMLButtonElement) {
            copyRepoCommandButton.classList.remove('is-copied');
            copyRepoCommandButton.textContent = 'Copiar';
          }
        }, 1600);
      } catch {
        if (copyRepoCommandButton instanceof HTMLButtonElement) {
          copyRepoCommandButton.textContent = 'No se pudo copiar';
          window.setTimeout(() => {
            if (copyRepoCommandButton instanceof HTMLButtonElement) {
              copyRepoCommandButton.textContent = 'Copiar';
            }
          }, 1600);
        }
      }
    });
  </script>
  <script is:inline id="repo-profile-json" type="application/json" set:html={JSON.stringify({
    id: repo.id,
    name: repo.name,
    fullName: repoFullName,
    githubUrl: repoWebUrl,
    description: repo.description || ''
  })}></script>
</Layout>
