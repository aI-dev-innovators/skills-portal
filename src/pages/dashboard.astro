---
import Layout from '../layouts/Layout.astro';
import { readReposConfig } from '../lib/config';
import { collectAllSkills, type SkillDoc } from '../lib/skill.service';
import DashboardHero from '../components/dashboard/DashboardHero.astro';
import DashboardEmptyState from '../components/dashboard/DashboardEmptyState.astro';
import DashboardKpiSections from '../components/dashboard/DashboardKpiSections.astro';
import DashboardFilters from '../components/dashboard/DashboardFilters.astro';
import DashboardDistributionPanels from '../components/dashboard/DashboardDistributionPanels.astro';
import DashboardSkillsTable from '../components/dashboard/DashboardSkillsTable.astro';

export const prerender = false;

const user = Astro.locals.user;
const session = Astro.locals.session;
const canManageRepositories = Astro.locals.canManageRepositories ?? false;

if (!canManageRepositories) {
  Astro.response.status = 403;
}

type FrontLabel =
  | 'Frontend'
  | 'Backend'
  | 'DevOps'
  | 'Security'
  | 'Cloud'
  | 'Data'
  | 'QA'
  | 'AI'
  | 'Mobile'
  | 'Otros';

interface DashboardSkillRecord {
  id: string;
  title: string;
  url: string;
  front: FrontLabel;
  technologies: string[];
  repoId: string;
  repoName: string;
  status: 'Activa' | 'Inactiva';
  createdAt: string;
}

const FRONTS: FrontLabel[] = [
  'Frontend',
  'Backend',
  'DevOps',
  'Security',
  'Cloud',
  'Data',
  'QA',
  'AI',
  'Mobile',
  'Otros'
];

const FRONT_KEYWORDS: Record<Exclude<FrontLabel, 'Otros'>, string[]> = {
  Frontend: ['frontend', 'angular', 'react', 'vue', 'next.js', 'nextjs', 'html', 'css', 'ui', 'ux', 'microfrontend'],
  Backend: ['backend', 'api', 'nestjs', 'node.js', 'nodejs', 'java', 'spring', 'microservicio', 'graphql', 'rest'],
  DevOps: ['devops', 'ci/cd', 'pipeline', 'docker', 'kubernetes', 'terraform', 'helm', 'jenkins', 'github actions'],
  Security: ['security', 'seguridad', 'owasp', 'iam', 'sast', 'dast', 'vulnerabilidad', 'autenticacion', 'auth'],
  Cloud: ['cloud', 'aws', 'azure', 'gcp', 'serverless', 'networking', 'storage', 'infraestructura'],
  Data: ['data', 'analytics', 'sql', 'etl', 'databricks', 'bigquery', 'database', 'reporting'],
  QA: ['qa', 'testing', 'test', 'selenium', 'cypress', 'playwright', 'junit', 'mock'],
  AI: ['ai', 'ia', 'llm', 'rag', 'prompt', 'genai', 'machine learning', 'openai', 'agent'],
  Mobile: ['mobile', 'android', 'ios', 'flutter', 'react native', 'kotlin', 'swift']
};

const TECHNOLOGY_KEYWORDS: Record<string, string[]> = {
  Java: ['java'],
  'Spring Boot': ['spring boot', 'spring'],
  Angular: ['angular'],
  React: ['react'],
  Vue: ['vue'],
  'Next.js': ['next.js', 'nextjs'],
  'Node.js': ['node.js', 'nodejs', 'nestjs'],
  TypeScript: ['typescript'],
  JavaScript: ['javascript'],
  Python: ['python'],
  Docker: ['docker'],
  Kubernetes: ['kubernetes', 'k8s'],
  Terraform: ['terraform'],
  Helm: ['helm'],
  Jenkins: ['jenkins'],
  'GitHub Actions': ['github actions'],
  GraphQL: ['graphql'],
  REST: ['rest'],
  AWS: ['aws'],
  Azure: ['azure'],
  GCP: ['gcp', 'google cloud'],
  Databricks: ['databricks'],
  BigQuery: ['bigquery'],
  SQL: ['sql'],
  Playwright: ['playwright'],
  Cypress: ['cypress'],
  Selenium: ['selenium'],
  JUnit: ['junit'],
  OpenAI: ['openai'],
  RAG: ['rag'],
  LLM: ['llm'],
  Flutter: ['flutter'],
  'React Native': ['react native'],
  Kotlin: ['kotlin'],
  Swift: ['swift']
};

function normalize(value: string): string {
  return value
    .toLowerCase()
    .normalize('NFD')
    .replace(/[\u0300-\u036f]/g, '')
    .replace(/[^a-z0-9\s./_-]/g, ' ')
    .replace(/\s+/g, ' ')
    .trim();
}

function toStatusLabel(status: SkillDoc['status']): 'Activa' | 'Inactiva' {
  return status === 'deprecated' ? 'Inactiva' : 'Activa';
}

function toDateLabel(value: string | null): string {
  if (!value) return 'N/D';
  const parsed = new Date(value);
  if (Number.isNaN(parsed.getTime())) return 'N/D';
  return parsed.toLocaleDateString('es-ES', {
    year: 'numeric',
    month: '2-digit',
    day: '2-digit'
  });
}

function detectFront(skill: SkillDoc): FrontLabel {
  const explicitTokens = [...(skill.tags || []), ...(skill.frameworks || [])].map((item) => normalize(item));

  const directMatch = FRONTS.find((front) => {
    if (front === 'Otros') return false;
    return explicitTokens.some((token) => FRONT_KEYWORDS[front].includes(token));
  });

  if (directMatch) return directMatch;

  const index = normalize([
    skill.title,
    skill.name,
    skill.description,
    skill.repoName,
    skill.repoId,
    ...(skill.tags || []),
    ...(skill.frameworks || [])
  ].join(' '));

  let bestFront: FrontLabel = 'Otros';
  let bestScore = 0;

  for (const front of FRONTS) {
    if (front === 'Otros') continue;
    let score = 0;
    for (const keyword of FRONT_KEYWORDS[front]) {
      if (index.includes(normalize(keyword))) score += 1;
    }
    if (score > bestScore) {
      bestScore = score;
      bestFront = front;
    }
  }

  return bestScore > 0 ? bestFront : 'Otros';
}

function detectTechnologies(skill: SkillDoc): string[] {
  const fromFrameworks = (skill.frameworks || [])
    .map((framework) => framework.trim())
    .filter(Boolean)
    .map((framework) => {
      const normalized = normalize(framework);
      if (normalized === 'node') return 'Node.js';
      if (normalized === 'react-native') return 'React Native';
      return framework;
    });

  const index = normalize([
    skill.title,
    skill.name,
    skill.description,
    skill.repoName,
    skill.repoId,
    ...(skill.tags || []),
    ...(skill.frameworks || [])
  ].join(' '));

  const detected = new Set<string>(fromFrameworks);
  for (const [technology, keywords] of Object.entries(TECHNOLOGY_KEYWORDS)) {
    for (const keyword of keywords) {
      if (index.includes(normalize(keyword))) {
        detected.add(technology);
        break;
      }
    }
  }

  return Array.from(detected).sort((a, b) => a.localeCompare(b));
}

const repos = await readReposConfig();
const skills = await collectAllSkills(repos);

const dashboardSkills: DashboardSkillRecord[] = skills.map((skill) => ({
  id: skill.id,
  title: skill.title,
  url: skill.url,
  front: detectFront(skill),
  technologies: detectTechnologies(skill),
  repoId: skill.repoId,
  repoName: skill.repoName,
  status: toStatusLabel(skill.status),
  createdAt: toDateLabel(skill.lastUpdated)
}));

const dashboardData = {
  skills: dashboardSkills,
  fronts: FRONTS,
  repositories: repos.map((repo) => ({ id: repo.id, name: repo.name }))
};
---

<Layout title="Dashboard" description="KPIs del catálogo de skills">
  <div class="dashboard-page">
  {canManageRepositories ? (
    <>
      <DashboardHero
        userLabel={user?.name ?? user?.email ?? 'No autenticado'}
        sessionLabel={session ? 'Activa' : 'Inactiva'}
      />

      <DashboardEmptyState
        id="empty-state-global"
        hidden={true}
        title="Sin datos"
        message="Aún no hay información para mostrar."
        titleId="empty-state-title"
        messageId="empty-state-message"
      />

      <section id="dashboard-content">
        <DashboardKpiSections />
        <DashboardFilters />
        <DashboardDistributionPanels />
        <DashboardSkillsTable />
      </section>

      <script id="dashboard-data" type="application/json">{JSON.stringify(dashboardData)}</script>

      <script>
        // @ts-nocheck
        const dashboardAdminStatus = document.getElementById('dashboard-admin-status');
        const payloadNode = document.getElementById('dashboard-data');
        const frontFilter = document.getElementById('filter-front');
        const techFilter = document.getElementById('filter-tech');
        const repoFilter = document.getElementById('filter-repo');
        const frontDistributionNode = document.getElementById('front-distribution');
        const technologyRankingNode = document.getElementById('technology-ranking');
        const repoRankingNode = document.getElementById('repo-ranking');
        const frontDonutChartNode = document.getElementById('front-donut-chart');
        const techBarsChartNode = document.getElementById('tech-bars-chart');
        const tableBodyNode = document.getElementById('skills-table-body');
        const tableEmptyNode = document.getElementById('table-empty');
        const showAllTechButton = document.getElementById('show-all-tech');
        const dashboardContent = document.getElementById('dashboard-content');
        const emptyStateGlobal = document.getElementById('empty-state-global');
        const emptyStateTitle = document.getElementById('empty-state-title');
        const emptyStateMessage = document.getElementById('empty-state-message');

        const kpiTotalSkills = document.getElementById('kpi-total-skills');
        const kpiActiveRepos = document.getElementById('kpi-active-repos');
        const kpiTotalFronts = document.getElementById('kpi-total-fronts');
        const kpiTotalTech = document.getElementById('kpi-total-tech');
        const kpiTopFront = document.getElementById('kpi-top-front');
        const kpiTopFrontHelp = document.getElementById('kpi-top-front-help');
        const kpiTopTech = document.getElementById('kpi-top-tech');
        const kpiTopTechHelp = document.getElementById('kpi-top-tech-help');
        const kpiTopRepo = document.getElementById('kpi-top-repo');
        const kpiTopRepoHelp = document.getElementById('kpi-top-repo-help');
        const kpiLowFront = document.getElementById('kpi-low-front');
        const kpiLowFrontHelp = document.getElementById('kpi-low-front-help');
        const kpiMeterSkills = document.getElementById('kpi-meter-skills');
        const kpiMeterRepos = document.getElementById('kpi-meter-repos');
        const kpiMeterFronts = document.getElementById('kpi-meter-fronts');
        const kpiMeterTech = document.getElementById('kpi-meter-tech');

        const payload = payloadNode && payloadNode.textContent
          ? JSON.parse(payloadNode.textContent)
          : { skills: [], fronts: [], repositories: [] };

        const allSkills = payload.skills || [];
        const allFronts = payload.fronts || [];
        const allRepositories = payload.repositories || [];
        let showAllTechnologies = false;

        function toPercent(count, total) {
          if (total <= 0) return 0;
          return Math.round((count / total) * 100);
        }

        function buildRankingMap(values) {
          const counts = new Map();
          values.forEach((value) => {
            if (!value) return;
            counts.set(value, (counts.get(value) || 0) + 1);
          });

          const total = values.length;
          return Array.from(counts.entries())
            .map(([key, count]) => ({ key, count, percent: toPercent(count, total) }))
            .sort((a, b) => b.count - a.count || a.key.localeCompare(b.key));
        }

        function computeSummary(rows) {
          const frontRanking = buildRankingMap(rows.map((row) => row.front));
          const techRanking = buildRankingMap(rows.flatMap((row) => row.technologies || []));
          const repoRanking = buildRankingMap(rows.map((row) => row.repoName || row.repoId));

          const lowCandidates = frontRanking.filter((item) => item.count > 0);
          const lowFront = lowCandidates.length
            ? lowCandidates.reduce((prev, current) => (current.count < prev.count ? current : prev), lowCandidates[0])
            : null;

          return {
            totalSkills: rows.length,
            activeRepos: allRepositories.length,
            frontDetected: frontRanking.length,
            technologiesDetected: techRanking.length,
            frontRanking,
            techRanking,
            repoRanking,
            topFront: frontRanking[0] || null,
            topTech: techRanking[0] || null,
            topRepo: repoRanking[0] || null,
            lowFront
          };
        }

        function renderKpis(summary) {
          if (kpiTotalSkills) kpiTotalSkills.textContent = String(summary.totalSkills);
          if (kpiActiveRepos) kpiActiveRepos.textContent = String(summary.activeRepos);
          if (kpiTotalFronts) kpiTotalFronts.textContent = String(summary.frontDetected);
          if (kpiTotalTech) kpiTotalTech.textContent = String(summary.technologiesDetected);

          const maxSkills = Math.max(allSkills.length, 1);
          const maxRepos = Math.max(allRepositories.length, 1);
          const maxFronts = Math.max(allFronts.length, 1);
          const allTechCount = Array.from(new Set(allSkills.flatMap((row) => row.technologies || []))).length;
          const maxTech = Math.max(allTechCount, 1);

          if (kpiMeterSkills) kpiMeterSkills.style.width = `${Math.max(8, Math.round((summary.totalSkills / maxSkills) * 100))}%`;
          if (kpiMeterRepos) kpiMeterRepos.style.width = `${Math.max(8, Math.round((summary.activeRepos / maxRepos) * 100))}%`;
          if (kpiMeterFronts) kpiMeterFronts.style.width = `${Math.max(8, Math.round((summary.frontDetected / maxFronts) * 100))}%`;
          if (kpiMeterTech) kpiMeterTech.style.width = `${Math.max(8, Math.round((summary.technologiesDetected / maxTech) * 100))}%`;

          if (kpiTopFront) kpiTopFront.textContent = summary.topFront ? summary.topFront.key : '-';
          if (kpiTopFrontHelp) kpiTopFrontHelp.textContent = summary.topFront ? `${summary.topFront.count} skills registradas` : '0 skills registradas';

          if (kpiTopTech) kpiTopTech.textContent = summary.topTech ? summary.topTech.key : '-';
          if (kpiTopTechHelp) kpiTopTechHelp.textContent = summary.topTech ? `${summary.topTech.count} skills asociadas` : '0 skills asociadas';

          if (kpiTopRepo) kpiTopRepo.textContent = summary.topRepo ? summary.topRepo.key : '-';
          if (kpiTopRepoHelp) kpiTopRepoHelp.textContent = summary.topRepo ? `${summary.topRepo.count} skills publicadas` : '0 skills publicadas';

          if (kpiLowFront) kpiLowFront.textContent = summary.lowFront ? summary.lowFront.key : '-';
          if (kpiLowFrontHelp) kpiLowFrontHelp.textContent = summary.lowFront ? `${summary.lowFront.count} skills registradas` : '0 skills registradas';
        }

        function renderFrontDonut(summary) {
          if (!frontDonutChartNode) return;
          const top = summary.frontRanking.slice(0, 5);
          if (!top.length) {
            frontDonutChartNode.innerHTML = '<p class="empty-inline">Sin datos para gráfico por frente.</p>';
            return;
          }

          const colors = ['#22c7b6', '#4e88ff', '#ffad49', '#ef6f8c', '#8f7dff'];
          const radius = 46;
          const cx = 62;
          const cy = 62;
          const circumference = 2 * Math.PI * radius;

          let offset = 0;
          const arcs = top.map((item, index) => {
            const segment = (item.percent / 100) * circumference;
            const dashArray = `${segment} ${circumference - segment}`;
            const dashOffset = -offset;
            offset += segment;
            return `<circle cx="${cx}" cy="${cy}" r="${radius}" fill="none" stroke="${colors[index % colors.length]}" stroke-width="14" stroke-linecap="butt" stroke-dasharray="${dashArray}" stroke-dashoffset="${dashOffset}"></circle>`;
          }).join('');

          const legend = top.map((item, index) => `
            <li>
              <span class="dot" style="background:${colors[index % colors.length]}"></span>
              <span>${item.key}</span>
              <strong>${item.percent}%</strong>
            </li>
          `).join('');

          frontDonutChartNode.innerHTML = `
            <div class="donut-wrap">
              <svg viewBox="0 0 124 124" aria-hidden="true" focusable="false">
                <circle cx="${cx}" cy="${cy}" r="${radius}" fill="none" stroke="color-mix(in srgb, var(--panel) 65%, var(--border))" stroke-width="14"></circle>
                ${arcs}
                <text x="50%" y="50%" text-anchor="middle" dominant-baseline="middle" class="donut-label">${summary.totalSkills}</text>
              </svg>
              <ul class="donut-legend">${legend}</ul>
            </div>
          `;
        }

        function renderTechBarsChart(summary) {
          if (!techBarsChartNode) return;
          const top = summary.techRanking.slice(0, 6);
          if (!top.length) {
            techBarsChartNode.innerHTML = '<p class="empty-inline">Sin datos para gráfico de tecnologías.</p>';
            return;
          }

          const maxCount = Math.max(...top.map((item) => item.count), 1);
          techBarsChartNode.innerHTML = top.map((item) => {
            const percent = Math.round((item.count / maxCount) * 100);
            return `
              <div class="tech-bar-row">
                <p>${item.key}</p>
                <div class="tech-bar-track"><span style="width:${Math.max(10, percent)}%"></span></div>
                <strong>${item.count}</strong>
              </div>
            `;
          }).join('');
        }

        function renderDistribution(summary) {
          if (!frontDistributionNode) return;

          frontDistributionNode.innerHTML = summary.frontRanking.map((item) => {
            const width = Math.max(item.percent, 4);
            return `
              <button class="list-row" type="button" data-front="${item.key}">
                <div class="list-row__head">
                  <span>${item.key}</span>
                  <strong>${item.count} skills · ${item.percent}%</strong>
                </div>
                <div class="list-row__bar"><span style="width:${width}%;"></span></div>
              </button>
            `;
          }).join('') || '<p class="empty-inline">Sin datos para distribución por frente.</p>';

          frontDistributionNode.querySelectorAll('button[data-front]').forEach((button) => {
            button.addEventListener('click', () => {
              if (!frontFilter) return;
              frontFilter.value = button.dataset.front || '';
              applyDashboardFilters();
            });
          });
        }

        function renderTechnologyRanking(summary) {
          if (!technologyRankingNode) return;
          const list = showAllTechnologies ? summary.techRanking : summary.techRanking.slice(0, 10);

          technologyRankingNode.innerHTML = list.map((item) => `
            <button class="list-row list-row--compact" type="button" data-tech="${item.key}">
              <span>${item.key}</span>
              <strong>${item.count} skills</strong>
            </button>
          `).join('') || '<p class="empty-inline">Sin tecnologías para este filtro.</p>';

          if (showAllTechButton) {
            const hasOverflow = summary.techRanking.length > 10;
            showAllTechButton.hidden = !hasOverflow;
            showAllTechButton.textContent = showAllTechnologies ? 'Ver top 10' : 'Ver todas';
          }

          technologyRankingNode.querySelectorAll('button[data-tech]').forEach((button) => {
            button.addEventListener('click', () => {
              if (!techFilter) return;
              techFilter.value = button.dataset.tech || '';
              applyDashboardFilters();
            });
          });
        }

        function renderRepositoryRanking(summary) {
          if (!repoRankingNode) return;

          repoRankingNode.innerHTML = summary.repoRanking.map((item) => `
            <button class="list-row list-row--compact" type="button" data-repo="${item.key}">
              <span>${item.key}</span>
              <strong>${item.count} skills</strong>
            </button>
          `).join('') || '<p class="empty-inline">Sin repositorios para este filtro.</p>';

          repoRankingNode.querySelectorAll('button[data-repo]').forEach((button) => {
            button.addEventListener('click', () => {
              if (!repoFilter) return;
              repoFilter.value = button.dataset.repo || '';
              applyDashboardFilters();
            });
          });
        }

        function renderTable(rows) {
          if (!tableBodyNode) return;

          if (!rows.length) {
            tableBodyNode.innerHTML = '';
            if (tableEmptyNode) tableEmptyNode.hidden = false;
            return;
          }

          if (tableEmptyNode) tableEmptyNode.hidden = true;

          const repoCounts = rows.reduce((acc, row) => {
            const key = row.repoName || row.repoId;
            acc.set(key, (acc.get(key) || 0) + 1);
            return acc;
          }, new Map());
          const maxTechPerSkill = Math.max(1, ...rows.map((row) => (row.technologies || []).length));

          tableBodyNode.innerHTML = rows.map((row) => {
            const technologies = row.technologies && row.technologies.length
              ? row.technologies.map((tech) => `<span class="badge badge--tech">${tech}</span>`).join(' ')
              : '<span class="badge badge--tech">N/D</span>';

            const frontClass = `badge badge--front badge--${row.front.toLowerCase().replace(/[^a-z]+/g, '-')}`;
            const statusClass = row.status === 'Activa' ? 'badge badge--status-active' : 'badge badge--status-inactive';
            const repoKey = row.repoName || row.repoId;
            const repoCount = repoCounts.get(repoKey) || 0;
            const repoShare = toPercent(repoCount, rows.length);
            const techCount = (row.technologies || []).length;
            const techDepth = Math.round((techCount / maxTechPerSkill) * 100);

            return `
              <tr>
                <td><a href="${row.url}">${row.title}</a></td>
                <td><span class="${frontClass}">${row.front}</span></td>
                <td>${technologies}</td>
                <td>${row.repoName || row.repoId}</td>
                <td>
                  <div class="row-metrics">
                    <div class="row-metric">
                      <span>Share repo</span>
                      <div class="mini-track"><span style="width:${Math.max(8, repoShare)}%"></span></div>
                      <strong>${repoShare}%</strong>
                    </div>
                    <div class="row-metric">
                      <span>Mix tech</span>
                      <div class="mini-track mini-track--tech"><span style="width:${Math.max(8, techDepth)}%"></span></div>
                      <strong>${techCount}</strong>
                    </div>
                  </div>
                </td>
                <td><span class="${statusClass}">${row.status}</span></td>
                <td>${row.createdAt}</td>
              </tr>
            `;
          }).join('');
        }

        function applyDashboardFilters() {
          const selectedFront = frontFilter ? frontFilter.value : '';
          const selectedTechnology = techFilter ? techFilter.value : '';
          const selectedRepository = repoFilter ? repoFilter.value : '';

          const filtered = allSkills.filter((row) => {
            const frontOk = !selectedFront || row.front === selectedFront;
            const technologyOk = !selectedTechnology || (row.technologies || []).includes(selectedTechnology);
            const repositoryOk = !selectedRepository || row.repoName === selectedRepository;
            return frontOk && technologyOk && repositoryOk;
          });

          const summary = computeSummary(filtered);
          renderKpis(summary);
          renderDistribution(summary);
          renderFrontDonut(summary);
          renderTechBarsChart(summary);
          renderTechnologyRanking(summary);
          renderRepositoryRanking(summary);
          renderTable(filtered);
        }

        function clearDashboardFilters() {
          if (frontFilter) frontFilter.value = '';
          if (techFilter) techFilter.value = '';
          if (repoFilter) repoFilter.value = '';
          showAllTechnologies = false;
          applyDashboardFilters();
        }

        async function clearDashboardCache() {
          const confirmed = window.confirm('Se limpiará la cache del catálogo. ¿Deseas continuar?');
          if (!confirmed) return;

          const trigger = document.querySelector('button[onclick="clearDashboardCache()"]');
          if (trigger) trigger.disabled = true;

          if (dashboardAdminStatus) {
            dashboardAdminStatus.textContent = 'Limpiando cache...';
          }

          try {
            const response = await fetch('/api/admin/cache-clear', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' }
            });
            const data = await response.json().catch(() => ({}));
            if (!response.ok) {
              throw new Error(String(data.error || 'No se pudo limpiar la cache'));
            }

            if (dashboardAdminStatus) {
              dashboardAdminStatus.textContent = 'Cache limpiada. Recargando dashboard...';
            }

            window.location.reload();
          } catch (error) {
            const message = error instanceof Error ? error.message : 'Error inesperado';
            if (dashboardAdminStatus) {
              dashboardAdminStatus.textContent = message;
            } else {
              window.alert(message);
            }
          } finally {
            if (trigger) trigger.disabled = false;
          }
        }

        function refreshDashboardMetrics() {
          applyDashboardFilters();
          if (dashboardAdminStatus) {
            dashboardAdminStatus.textContent = 'Métricas actualizadas correctamente.';
          }
        }

        function initializeOptions() {
          setSelectOptions(
            frontFilter,
            allFronts.map((front) => ({ value: front, label: front })),
            'Todos los frentes'
          );

          const technologies = Array.from(new Set(allSkills.flatMap((row) => row.technologies || []))).sort((a, b) => a.localeCompare(b));
          setSelectOptions(
            techFilter,
            technologies.map((technology) => ({ value: technology, label: technology })),
            'Todas las tecnologías'
          );

          const repositoryOptions = allRepositories
            .map((repo) => ({ value: repo.name, label: repo.name }))
            .sort((a, b) => a.label.localeCompare(b.label));
          setSelectOptions(repoFilter, repositoryOptions, 'Todos los repositorios');
        }

        function setSelectOptions(select, options, defaultLabel) {
          if (!select) return;
          select.innerHTML = [`<option value="">${defaultLabel}</option>`]
            .concat(options.map((opt) => `<option value="${opt.value}">${opt.label}</option>`))
            .join('');
        }

        function bootstrapDashboard() {
          const hasSkills = allSkills.length > 0;
          const hasRepos = allRepositories.length > 0;

          if (!hasSkills || !hasRepos) {
            if (dashboardContent) dashboardContent.hidden = true;
            if (emptyStateGlobal) emptyStateGlobal.hidden = false;

            if (!hasSkills) {
              if (emptyStateTitle) emptyStateTitle.textContent = 'Aún no hay skills registradas en el catálogo.';
              if (emptyStateMessage) emptyStateMessage.textContent = 'Agrega un repositorio para comenzar a poblar el dashboard.';
            } else {
              if (emptyStateTitle) emptyStateTitle.textContent = 'No hay repositorios activos disponibles.';
              if (emptyStateMessage) emptyStateMessage.textContent = 'Activa o agrega un repositorio para calcular métricas.';
            }
            return;
          }

          if (dashboardContent) dashboardContent.hidden = false;
          if (emptyStateGlobal) emptyStateGlobal.hidden = true;

          initializeOptions();

          if (frontFilter) frontFilter.addEventListener('change', applyDashboardFilters);
          if (techFilter) techFilter.addEventListener('change', applyDashboardFilters);
          if (repoFilter) repoFilter.addEventListener('change', applyDashboardFilters);

          if (showAllTechButton) {
            showAllTechButton.addEventListener('click', () => {
              showAllTechnologies = !showAllTechnologies;
              applyDashboardFilters();
            });
          }

          applyDashboardFilters();
        }

        bootstrapDashboard();

        window.clearDashboardCache = clearDashboardCache;
        window.refreshDashboardMetrics = refreshDashboardMetrics;
        window.clearDashboardFilters = clearDashboardFilters;
      </script>
    </>
  ) : (
    <section class="forbidden" aria-live="polite">
      <h1>Acceso restringido</h1>
      <p>No tienes permisos para visualizar el dashboard administrativo.</p>
    </section>
  )}

