<section class="kpi-grid" aria-label="KPIs principales">
    <article class="kpi-card">
      <p class="kpi-label">Skills publicadas</p>
      <p class="kpi-value" id="kpi-total-skills">0</p>
      <div class="kpi-meter" aria-hidden="true"><span id="kpi-meter-skills"></span></div>
      <p class="kpi-help">Total de skills disponibles en el catálogo.</p>
    </article>
    <article class="kpi-card">
      <p class="kpi-label">Repositorios activos</p>
      <p class="kpi-value" id="kpi-active-repos">0</p>
      <div class="kpi-meter" aria-hidden="true"><span id="kpi-meter-repos"></span></div>
      <p class="kpi-help">Repositorios activos conectados al catálogo.</p>
    </article>
    <article class="kpi-card">
      <p class="kpi-label">Frentes tecnológicos</p>
      <p class="kpi-value" id="kpi-total-fronts">0</p>
      <div class="kpi-meter" aria-hidden="true"><span id="kpi-meter-fronts"></span></div>
      <p class="kpi-help">Categorías principales detectadas en las skills.</p>
    </article>
    <article class="kpi-card">
      <p class="kpi-label">Tecnologías detectadas</p>
      <p class="kpi-value" id="kpi-total-tech">0</p>
      <div class="kpi-meter" aria-hidden="true"><span id="kpi-meter-tech"></span></div>
      <p class="kpi-help">Tecnologías únicas identificadas en el catálogo.</p>
    </article>
</section>

<section class="kpi-grid" aria-label="KPIs secundarios">
    <article class="kpi-card">
      <p class="kpi-label">Frente con más skills</p>
      <p class="kpi-value kpi-value--compact" id="kpi-top-front">-</p>
      <p class="kpi-help" id="kpi-top-front-help">0 skills registradas</p>
    </article>
    <article class="kpi-card">
      <p class="kpi-label">Tecnología principal</p>
      <p class="kpi-value kpi-value--compact" id="kpi-top-tech">-</p>
      <p class="kpi-help" id="kpi-top-tech-help">0 skills asociadas</p>
    </article>
    <article class="kpi-card">
      <p class="kpi-label">Repositorio principal</p>
      <p class="kpi-value kpi-value--compact" id="kpi-top-repo">-</p>
      <p class="kpi-help" id="kpi-top-repo-help">0 skills publicadas</p>
    </article>
    <article class="kpi-card">
      <p class="kpi-label">Menor cobertura</p>
      <p class="kpi-value kpi-value--compact" id="kpi-low-front">-</p>
      <p class="kpi-help" id="kpi-low-front-help">0 skills registradas</p>
    </article>
</section>
