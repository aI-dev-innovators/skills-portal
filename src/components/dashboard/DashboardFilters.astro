<section class="filters" aria-label="Filtros del dashboard">
  <h2>Filtros</h2>
  <div class="filter-grid">
    <label>
      Frente
      <select id="filter-front">
        <option value="">Todos los frentes</option>
      </select>
    </label>
    <label>
      Tecnología
      <select id="filter-tech">
        <option value="">Todas las tecnologías</option>
      </select>
    </label>
    <label>
      Repositorio
      <select id="filter-repo">
        <option value="">Todos los repositorios</option>
      </select>
    </label>
  </div>
  <div class="filter-actions">
    <button class="admin-action admin-action--secondary" type="button" onclick="clearDashboardFilters()">Limpiar filtros</button>
  </div>
</section>
